{
  "_comment": [
    "AgriSync OTLP Collector — ECS Fargate Task Definition Template",
    "T-IGH-05-OTEL-PROD",
    "",
    "USAGE: Fill in <PLACEHOLDERS> and register with:",
    "  aws ecs register-task-definition --cli-input-json file://task-definition.json",
    "",
    "IMAGE PIN: Update otel/opentelemetry-collector-contrib version in concert with",
    "  otel-collector-config.yaml comment header. Never use :latest in production.",
    "",
    "NETWORKING: This task MUST be deployed in PRIVATE subnets only. The security",
    "  group allows inbound 4317/4318 from the backend task security group ONLY.",
    "  See SECURITY_NOTES.md for the full VPC wiring.",
    "",
    "SECRETS: GRAFANA_OTLP_ENDPOINT, GRAFANA_INSTANCE_ID, GRAFANA_API_TOKEN are",
    "  pulled from AWS Secrets Manager — never as plain environment variables.",
    "  See 'secrets' array below."
  ],
  "family": "agrisync-otel-collector",
  "taskRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/agrisync-otel-collector-task",
  "executionRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/agrisync-otel-collector-execution",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "otel-collector",
      "image": "otel/opentelemetry-collector-contrib:0.103.0",
      "essential": true,
      "command": [
        "--config=/etc/otelcol/otel-collector-config.yaml"
      ],
      "mountPoints": [
        {
          "sourceVolume": "otel-config",
          "containerPath": "/etc/otelcol",
          "readOnly": true
        }
      ],
      "portMappings": [
        {
          "name": "otlp-grpc",
          "containerPort": 4317,
          "hostPort": 4317,
          "protocol": "tcp",
          "appProtocol": "grpc"
        },
        {
          "name": "otlp-http",
          "containerPort": 4318,
          "hostPort": 4318,
          "protocol": "tcp"
        },
        {
          "name": "health",
          "containerPort": 13133,
          "hostPort": 13133,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "_comment": "OTEL_BACKEND is informational; actual backend is wired in otel-collector-config.yaml",
          "name": "OTEL_BACKEND",
          "value": "grafana"
        }
      ],
      "secrets": [
        {
          "name": "GRAFANA_OTLP_ENDPOINT",
          "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:agrisync/prod/grafana-otlp-endpoint"
        },
        {
          "name": "GRAFANA_INSTANCE_ID",
          "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:agrisync/prod/grafana-instance-id"
        },
        {
          "name": "GRAFANA_API_TOKEN",
          "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:agrisync/prod/grafana-api-token"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/agrisync-otel-collector",
          "awslogs-region": "<REGION>",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      },
      "healthCheck": {
        "command": [
          "CMD",
          "wget",
          "--no-verbose",
          "--tries=1",
          "--spider",
          "http://localhost:13133/"
        ],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 15
      },
      "stopTimeout": 30,
      "readonlyRootFilesystem": false,
      "privileged": false,
      "user": "nobody"
    }
  ],
  "volumes": [
    {
      "name": "otel-config",
      "_comment": [
        "The otel-collector-config.yaml must be uploaded to S3 or baked into an ECR image.",
        "For MVP: use an S3-backed volume via a sidecar init container that copies the config.",
        "Alternative: build a custom ECR image FROM otel/opentelemetry-collector-contrib:0.103.0",
        "  that COPYs otel-collector-config.yaml into /etc/otelcol/. This is preferred for",
        "  deterministic deployments. See README.md §3 (Config delivery options)."
      ]
    }
  ],
  "tags": [
    { "key": "Project", "value": "AgriSync" },
    { "key": "Component", "value": "OtelCollector" },
    { "key": "ManagedBy", "value": "Kiro" },
    { "key": "Task", "value": "T-IGH-05-OTEL-PROD" }
  ]
}
