{
  "_comment": [
    "AgriSync OTLP Collector — ECS Fargate Task Definition Template",
    "T-IGH-05-OTEL-PROD",
    "",
    "USAGE: Fill in <PLACEHOLDERS> and register with:",
    "  aws ecs register-task-definition --cli-input-json file://task-definition.json",
    "",
    "IMAGE PIN: Update ECR image tag in concert with otel-collector-config.yaml comment",
    "  header. Never use :latest in production.",
    "",
    "NETWORKING: This task MUST be deployed in PRIVATE subnets only. The security",
    "  group allows inbound 4317/4318 from the backend task security group ONLY.",
    "  See SECURITY_NOTES.md for the full VPC wiring.",
    "",
    "SECRETS: GRAFANA_OTLP_ENDPOINT and GRAFANA_BASIC_AUTH_BASE64 are pulled from",
    "  AWS Secrets Manager — never as plain environment variables.",
    "  GRAFANA_BASIC_AUTH_BASE64 = base64(instance_id:api_token) — see SECURITY_NOTES.md §Secrets.",
    "  See 'secrets' array below.",
    "",
    "IMAGE: Custom ECR image with config baked in (Risk B fix, 2026-05-03).",
    "  Build via: cd aws/otel-collector && docker build -t agrisync-otel-collector:0.103.0 .",
    "  See README.md §1 (Image build) for full push commands."
  ],
  "family": "agrisync-otel-collector",
  "taskRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/agrisync-otel-collector-task",
  "executionRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/agrisync-otel-collector-execution",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "otel-collector",
      "image": "<ACCOUNT_ID>.dkr.ecr.<REGION>.amazonaws.com/agrisync-otel-collector:0.103.0",
      "essential": true,
      "command": [
        "--config=/etc/otelcol-contrib/config.yaml"
      ],
      "portMappings": [
        {
          "name": "otlp-grpc",
          "containerPort": 4317,
          "hostPort": 4317,
          "protocol": "tcp",
          "appProtocol": "grpc"
        },
        {
          "name": "otlp-http",
          "containerPort": 4318,
          "hostPort": 4318,
          "protocol": "tcp"
        },
        {
          "name": "health",
          "containerPort": 13133,
          "hostPort": 13133,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "_comment": "OTEL_BACKEND is informational; actual backend is wired in otel-collector-config.yaml",
          "name": "OTEL_BACKEND",
          "value": "grafana"
        }
      ],
      "secrets": [
        {
          "name": "GRAFANA_OTLP_ENDPOINT",
          "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:agrisync/prod/grafana-otlp-endpoint"
        },
        {
          "name": "GRAFANA_BASIC_AUTH_BASE64",
          "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:agrisync/prod/grafana-basic-auth-base64"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/agrisync-otel-collector",
          "awslogs-region": "<REGION>",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      },
      "healthCheck": {
        "command": [
          "CMD",
          "wget",
          "--no-verbose",
          "--tries=1",
          "--spider",
          "http://localhost:13133/"
        ],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 15
      },
      "stopTimeout": 30,
      "readonlyRootFilesystem": false,
      "privileged": false,
      "user": "nobody"
    }
  ],
  "tags": [
    { "key": "Project", "value": "AgriSync" },
    { "key": "Component", "value": "OtelCollector" },
    { "key": "ManagedBy", "value": "Kiro" },
    { "key": "Task", "value": "T-IGH-05-OTEL-PROD" }
  ]
}
