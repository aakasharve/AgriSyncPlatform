{
  "name": "@agrisync/sync-contract",
  "version": "0.1.0",
  "private": true,
  "description": "Canonical sync mutation contract (single source of truth for client + server)",
  "type": "module",
  "scripts": {
    "validate": "node scripts/validate.mjs",
    "generate": "node scripts/generate.mjs && tsx scripts/generate-csharp-payloads.ts",
    "generate:csharp": "tsx scripts/generate-csharp-payloads.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.0",
    "zod": "^3.23.8"
  }
}
