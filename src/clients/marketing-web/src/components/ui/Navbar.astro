---
import { getLangFromUrl, getTranslations } from '../../i18n/translations';
import BrandLogo from '../svg/BrandLogo.astro';

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
const oppositeLang = lang === 'en' ? '/mr/' : '/en/';
// Always Latin script. Highlight current lang, dim the other.
const isEn = lang === 'en';
---

<div id="nav-sentinel" aria-hidden="true" style="position: absolute; top: 0; left: 0; width: 1px; height: 1px;"></div>

<nav
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50"
  aria-label="Main navigation"
>
  <div class="max-w-site mx-auto flex items-center justify-between h-16 px-5 md:px-8">
    <a href={`/${lang}/`} class="flex items-center transition-all duration-300">
      <BrandLogo compact class="nav-logo" />
    </a>

    <div class="flex items-center gap-3 md:gap-5">
      <a
  href={oppositeLang}
  class="nav-lang-toggle flex items-center gap-1 text-xs font-bold tracking-widest uppercase transition-colors duration-300 px-2 py-1"
  aria-label={isEn ? 'Switch to Marathi' : 'Switch to English'}
>
  <span style={isEn ? 'color:#fff;' : 'color:rgba(255,255,255,0.35);'}>EN</span>
  <span style="color:rgba(255,255,255,0.25);">·</span>
  <span style={!isEn ? 'color:#fff;' : 'color:rgba(255,255,255,0.35);'}>MR</span>
</a>

      <a
        href="https://app.shramsafal.com"
        class="inline-flex items-center gap-2 bg-brand text-white text-sm font-bold px-4 py-2 rounded-lg hover:bg-brand-hover transition-colors shadow-sm"
      >
        {t.nav.open_app}
      </a>
    </div>
  </div>
</nav>

<div
  id="sticky-cta"
  class="fixed bottom-0 left-0 right-0 z-40 p-3 md:hidden translate-y-full transition-transform duration-300"
  aria-hidden="true"
>
  <a
    href="#guided-questions"
    class="flex items-center justify-center bg-brand text-white font-extrabold text-base py-3.5 rounded-full shadow-lg shadow-brand/30 w-full"
  >
    {t.nav.cta_sticky}
  </a>
</div>

<style>
  .nav-logo { transition: opacity 0.3s ease; }
  .nav-logo:hover { opacity: 0.8; }

  #main-nav {
    background: transparent;
    border-bottom: 1px solid transparent;
    transition: background 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  #main-nav.navbar-solid {
    background: rgba(6,15,7,0.88);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    box-shadow: 0 1px 24px rgba(0,0,0,0.3);
  }
</style>

<script>
  const nav = document.getElementById('main-nav');
  const sentinel = document.getElementById('nav-sentinel');

  if (nav && sentinel) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          nav.classList.remove('navbar-solid');
        } else {
          nav.classList.add('navbar-solid');
        }
      },
      { threshold: 1.0 }
    );
    observer.observe(sentinel);
  }

  const stickyCta = document.getElementById('sticky-cta');
  if (stickyCta) {
    const sticky = stickyCta;
    const footer = document.querySelector('footer');
    let footerVisible = false;

    if (footer) {
      const footerObserver = new IntersectionObserver(
        ([entry]) => { footerVisible = entry.isIntersecting; updateStickyCta(); },
        { threshold: 0.1 }
      );
      footerObserver.observe(footer);
    }

    function updateStickyCta() {
      const scrollPercent = window.scrollY / (document.documentElement.scrollHeight - window.innerHeight);
      const show = scrollPercent > 0.3 && !footerVisible;
      sticky.classList.toggle('translate-y-full', !show);
      sticky.classList.toggle('translate-y-0', show);
      sticky.setAttribute('aria-hidden', String(!show));
    }

    window.addEventListener('scroll', updateStickyCta, { passive: true });
  }
</script>
