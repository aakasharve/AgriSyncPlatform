---
import { getLangFromUrl, getTranslations } from '../../i18n/translations';

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
const year = new Date().getFullYear();
const logoSrc =
  lang === 'mr'
    ? '/brand-assets/logo-mr-transparent.svg'
    : '/brand-assets/footer-logo-exact.svg';
const logoAlt = lang === 'mr' ? 'श्रम सफल' : 'ShramSafal';
const showFooterCopy = true;
---

<footer class="relative pt-16 md:pt-20 pb-0 overflow-hidden" style="background:#F7F1E6;border-top:1px solid rgba(146,64,14,0.12);">
  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 60% 50% at 50% 100%, rgba(20,83,45,0.05), transparent 60%);" aria-hidden="true"></div>

  <div class="relative z-10 max-w-site mx-auto px-5 md:px-8">

    <!-- Logo + tagline -->
    <div class="text-center mb-10">
      <div class="flex items-center justify-center mb-6">
        <div class="footer-logo-frame">
          <img
            src={logoSrc}
            alt={logoAlt}
            class="footer-logo"
            loading="eager"
            decoding="async"
          />
        </div>
      </div>

      {showFooterCopy && (
        <>
          <p class="text-sm md:text-base mb-2 max-w-md mx-auto leading-relaxed" style="color:var(--text-secondary);">
            {t.footer.tagline}
          </p>
          {t.footer.subline && (
            <p class="text-xs md:text-sm max-w-md mx-auto" style="color:var(--text-muted);">
              {t.footer.subline}
            </p>
          )}
        </>
      )}
    </div>

    <!-- Middle row: CTA + contact -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-10">
      <a
        href="#cta"
        class="inline-flex items-center gap-2 font-extrabold text-sm px-5 py-3 rounded-xl transition-all duration-200 hover:-translate-y-0.5"
        style="background:linear-gradient(135deg,var(--brand),var(--brand-fresh));color:#fff;box-shadow:0 6px 20px rgba(20,83,45,0.22);"
      >
        {lang === 'mr' ? 'लवकर सहभागी व्हा' : 'Join early access'}
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>

      <a
        href="https://wa.me/919999999999"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm font-bold transition-colors hover:opacity-80"
        style="color:var(--brand);"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
        </svg>
        WhatsApp
      </a>
    </div>

    <!-- Bottom bar -->
    <div class="border-t pt-6 mb-16 flex flex-col sm:flex-row items-center justify-between gap-3 text-center" style="border-color:rgba(146,64,14,0.10);">
      <p class="text-[11px] tracking-widest uppercase" style="color:var(--text-muted);">
        &copy; {year} ShramSafal — {t.footer.copyright}
      </p>
      <div class="flex items-center gap-4">
        <a
          href={lang === 'mr' ? '/en/' : '/mr/'}
          class="text-[11px] tracking-widest uppercase font-bold transition-colors hover:opacity-80"
          style="color:var(--text-muted);"
        >
          {lang === 'mr' ? 'English' : 'मराठी'}
        </a>
      </div>
    </div>

  </div>

  <!--
    White fade-out — the page closes gracefully rather than cutting to browser chrome.
    Gradient: footer clay → pure white over 5rem.
  -->
  <div
    aria-hidden="true"
    style="
      position: relative;
      z-index: 10;
      height: 5rem;
      background: linear-gradient(to bottom, transparent 0%, rgba(255,255,255,0.40) 40%, rgba(255,255,255,0.82) 70%, #ffffff 100%);
      pointer-events: none;
    "
  ></div>
</footer>

<style>
  .footer-logo-frame {
    width: min(44rem, 95vw);
    height: min(11rem, 24vw);
    margin-inline: auto;
    overflow: hidden;
  }

  .footer-logo {
    display: block;
    width: 100%;
    height: auto;
    max-width: none;
    transform: translateY(-30.5%);
    transform-origin: center center;
    filter: drop-shadow(0 10px 24px rgba(0,0,0,0.10));
  }

  @media (min-width: 768px) {
    .footer-logo-frame {
      width: min(62rem, 84vw);
      height: min(14.5rem, 20vw);
    }
  }
</style>
