---
import { getLangFromUrl, getTranslations } from '../../i18n/translations';
import BrandLogo from '../svg/BrandLogo.astro';

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="relative text-white py-16 md:py-20 overflow-hidden" style="background:#020c06;border-top:1px solid rgba(245,158,11,0.2);">
  <div class="absolute inset-0 pointer-events-none opacity-[0.06] bg-[radial-gradient(circle_at_center,rgba(16,185,129,0.08),transparent_60%)]" aria-hidden="true"></div>

  <div class="relative z-10 max-w-site mx-auto px-5 md:px-8 text-center">
    <div class="flex items-center justify-center mb-4">
      <BrandLogo light class="scale-95 md:scale-100" />
    </div>

    <p class="text-white/50 text-sm md:text-base mb-2 max-w-md mx-auto leading-relaxed">
      {t.footer.tagline}
    </p>
    <p class="text-white/35 text-xs md:text-sm mb-8 max-w-md mx-auto">
      {t.footer.subline}
    </p>

    <div class="mb-10">
      <a
        href="https://wa.me/919999999999"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-brand-fresh/80 text-sm font-bold hover:text-brand-fresh transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
        </svg>
        WhatsApp
      </a>
    </div>

    <div class="w-16 h-px mx-auto mb-6" style="border-color:rgba(255,255,255,0.08);border-bottom:1px solid rgba(255,255,255,0.08);"></div>

    <p class="text-[11px] text-white/25 tracking-widest uppercase">
      &copy; {year} ShramSafal &mdash; {t.footer.copyright}
    </p>
  </div>
</footer>
