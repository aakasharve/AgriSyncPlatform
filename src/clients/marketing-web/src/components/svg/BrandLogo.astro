---
interface Props {
  light?: boolean;
  compact?: boolean;
  class?: string;
  lang?: 'en' | 'mr';
}

const {
  light = false,
  compact = false,
  class: className = '',
  lang = 'en',
} = Astro.props;

const iconSrc = '/brand-assets/icon-transparent.svg';
const textSrc =
  lang === 'mr'
    ? '/brand-assets/text-mr-transparent.svg'
    : '/brand-assets/text-en-transparent.svg';

const alt = compact ? 'Shram Safal icon' : (lang === 'mr' ? 'श्रम सफल' : 'Shram Safal');
---

{compact ? (
  <img
    src={iconSrc}
    alt={alt}
    class={className}
    loading="eager"
    decoding="async"
    style="display:block;height:34px;width:34px;object-fit:contain;"
  />
) : (
  <div class:list={['brand-lockup', className]} aria-label={alt}>
    <img
      src={iconSrc}
      alt=""
      aria-hidden="true"
      class="brand-lockup__icon"
      loading="eager"
      decoding="async"
    />
    <img
      src={textSrc}
      alt={alt}
      class="brand-lockup__text"
      loading="eager"
      decoding="async"
    />
  </div>
)}

<style>
  .brand-lockup {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
  }

  .brand-lockup__icon {
    display: block;
    width: 3.6rem;
    height: 3.6rem;
    object-fit: contain;
    flex: 0 0 auto;
    filter: drop-shadow(0 8px 20px rgba(0,0,0,0.12));
  }

  .brand-lockup__text {
    display: block;
    height: 2.8rem;
    width: auto;
    object-fit: contain;
    flex: 0 1 auto;
    filter: drop-shadow(0 8px 20px rgba(0,0,0,0.10));
  }
</style>
