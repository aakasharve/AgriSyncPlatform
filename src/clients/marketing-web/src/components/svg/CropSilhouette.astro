---
// src/components/svg/CropSilhouette.astro
// Bottom-anchored crop stalk silhouettes. Always position:absolute bottom:0.
interface Props {
  count?: number;
  variant?: 'sugarcane' | 'maize' | 'mixed';
  goldGlow?: boolean;
  height?: number;
  class?: string;
}
const {
  count = 20,
  variant = 'mixed',
  goldGlow = false,
  height = 100,
  class: className = '',
} = Astro.props;

// Generate stalk positions deterministically (no Math.random — SSR safe)
function getStalks(n: number) {
  return Array.from({ length: n }, (_, i) => {
    const x = (i / (n - 1)) * 1400 + 20;
    // Alternating heights based on index
    const h = variant === 'sugarcane'
      ? 55 + ((i * 17) % 40)
      : variant === 'maize'
      ? 45 + ((i * 13) % 35)
      : i % 2 === 0 ? 55 + ((i * 17) % 40) : 45 + ((i * 11) % 30);
    const w = variant === 'sugarcane' ? 2.5 : 3;
    const opacity = 0.18 + ((i * 7) % 12) / 100;
    return { x, h, w, opacity };
  });
}

const stalks = getStalks(count);
const vbHeight = height;
---

<div
  class={`crop-silhouette ${className}`}
  aria-hidden="true"
  style={`position:absolute;bottom:0;left:0;right:0;height:${height}px;pointer-events:none;z-index:3;`}
>
  <svg
    viewBox={`0 0 1440 ${vbHeight}`}
    xmlns="http://www.w3.org/2000/svg"
    preserveAspectRatio="none"
    style="width:100%;height:100%;display:block;"
    aria-hidden="true"
  >
    {/* Golden glow base */}
    {goldGlow && (
      <ellipse
        cx="720" cy={vbHeight}
        rx="900" ry={vbHeight * 0.7}
        fill="rgba(245,158,11,0.07)"
      />
    )}

    {/* Crop stalks */}
    {stalks.map(s => (
      <rect
        x={s.x} y={vbHeight - s.h}
        width={s.w} height={s.h}
        rx="1"
        fill={`rgba(16,185,129,${s.opacity})`}
      />
    ))}

    {/* Ground fill */}
    <path
      d={`M0 ${vbHeight - 14} Q360 ${vbHeight - 20} 720 ${vbHeight - 16} Q1080 ${vbHeight - 12} 1440 ${vbHeight - 18} L1440 ${vbHeight} L0 ${vbHeight} Z`}
      fill="rgba(245,158,11,0.055)"
    />

    {/* Golden horizon line */}
    {goldGlow && (
      <line
        x1="0" y1={vbHeight - 18}
        x2="1440" y2={vbHeight - 18}
        stroke="rgba(245,158,11,0.25)"
        stroke-width="1"
      />
    )}
  </svg>
</div>
