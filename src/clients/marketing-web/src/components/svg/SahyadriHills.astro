---
// src/components/svg/SahyadriHills.astro
// Renders one layer of the Sahyadri/Deccan hill silhouette.
// Use three times with depth=1,2,3 for parallax layering.
interface Props {
  depth: 1 | 2 | 3;
  class?: string;
}
const { depth, class: className = '' } = Astro.props;

// Each depth has different fill darkness and parallax data
const configs = {
  1: { fill: 'rgba(4,18,6,0.95)',  opacity: '1',    rate: '3',  zIndex: '-9'  },
  2: { fill: 'rgba(6,28,9,0.80)',  opacity: '0.85', rate: '6',  zIndex: '-8'  },
  3: { fill: 'rgba(10,40,13,0.60)',opacity: '0.65', rate: '10', zIndex: '-7'  },
} as const;

const cfg = configs[depth];

// Path varies per depth for visual variety
const paths: Record<1|2|3, string> = {
  1: 'M0 140 C60 100 130 60 210 78 C280 94 330 45 410 58 C490 71 550 30 640 42 C720 53 780 20 860 32 C940 44 1000 15 1080 28 C1160 41 1230 10 1300 22 C1360 32 1410 18 1440 26 L1440 140 Z',
  2: 'M0 140 C80 112 160 90 260 100 C360 110 420 78 520 88 C620 98 690 65 790 75 C880 84 950 55 1050 66 C1150 77 1230 50 1330 60 C1380 65 1420 54 1440 58 L1440 140 Z',
  3: 'M0 140 C100 124 190 108 300 116 C410 124 480 100 580 108 C680 116 750 92 850 100 C950 108 1030 86 1130 94 C1220 101 1310 82 1380 88 L1440 92 L1440 140 Z',
};
---

<div
  class={`sahyadri-layer sahyadri-layer--${depth} ${className}`}
  data-parallax
  data-parallax-rate={cfg.rate}
  aria-hidden="true"
  style={`position:absolute;bottom:0;left:0;right:0;height:140px;z-index:${cfg.zIndex};pointer-events:none;opacity:${cfg.opacity};`}
>
  <svg
    viewBox="0 0 1440 140"
    xmlns="http://www.w3.org/2000/svg"
    preserveAspectRatio="none"
    style="width:100%;height:100%;display:block;"
    aria-hidden="true"
  >
    <path d={paths[depth]} fill={cfg.fill} />
  </svg>
</div>
