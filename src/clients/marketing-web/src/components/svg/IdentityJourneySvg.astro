---
interface Props {
  lang?: 'en' | 'mr';
}

const { lang = 'en' } = Astro.props;

const labels =
  lang === 'mr'
    ? ['गोंधळ', 'जाणीव', 'नियंत्रण']
    : ['Overload', 'Awareness', 'Control'];
---

<svg viewBox="0 0 820 320" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto" aria-hidden="true">
  <defs>
    <linearGradient id="ij-card" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#FFF8EE" />
      <stop offset="100%" stop-color="#F2F7EF" />
    </linearGradient>
    <linearGradient id="ij-shirt" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#FFFDF8" />
      <stop offset="100%" stop-color="#ECE5D7" />
    </linearGradient>
    <filter id="ij-shadow" x="-10%" y="-10%" width="120%" height="130%">
      <feDropShadow dx="0" dy="10" stdDeviation="10" flood-color="#163826" flood-opacity="0.12" />
    </filter>
  </defs>

  <rect x="8" y="8" width="804" height="304" rx="28" fill="rgba(255,255,255,0.08)" stroke="rgba(255,255,255,0.10)" />
  <line x1="50" y1="266" x2="770" y2="266" stroke="rgba(255,255,255,0.12)" />

  {[0, 1, 2].map((index) => {
    const x = 110 + index * 250;
    const moodOpacity = index === 0 ? 0.55 : index === 1 ? 0.82 : 1;
    const shirtGlow = index === 2 ? 'rgba(16,185,129,0.14)' : index === 1 ? 'rgba(245,158,11,0.12)' : 'rgba(255,255,255,0.04)';

    return (
      <g transform={`translate(${x} 36)`} opacity={moodOpacity} filter="url(#ij-shadow)">
        <ellipse cx="0" cy="34" rx="28" ry="34" fill="#A97C53" />
        <ellipse cx="-10" cy="34" rx="3" ry="7" fill="#A97C53" />
        <ellipse cx="10" cy="34" rx="3" ry="7" fill="#A97C53" />
        <path d="M-18 22 C-10 10 10 10 18 22 C10 14 -10 14 -18 22Z" fill="#4A2F1B" />
        <circle cx="-8" cy="30" r="2.4" fill="#2B1A11" />
        <circle cx="8" cy="30" r="2.4" fill="#2B1A11" />
        <path d={index === 0 ? 'M-8 46 C-2 44 2 44 8 46' : index === 1 ? 'M-8 45 C-2 46 2 46 8 45' : 'M-8 43 C-2 47 2 47 8 43'} stroke="#6D4A31" stroke-width="2.2" fill="none" stroke-linecap="round" />

        <path d="M-10 70 C-18 84 -24 112 -24 152 L-20 224 C-20 232 -4 238 0 238 C4 238 20 232 20 224 L24 152 C24 112 18 84 10 70 C8 66 4 64 0 64 C-4 64 -8 66 -10 70Z" fill="url(#ij-shirt)" />
        <ellipse cx="0" cy="156" rx="52" ry="76" fill={shirtGlow} />
        <path d="M-28 98 C-40 122 -42 160 -36 188" stroke="#A97C53" stroke-width="14" stroke-linecap="round" />
        <path d="M28 98 C40 122 42 160 36 188" stroke="#A97C53" stroke-width="14" stroke-linecap="round" />
        <path d="M-12 236 L-16 272" stroke="#8B7D6B" stroke-width="18" stroke-linecap="round" />
        <path d="M12 236 L16 272" stroke="#8B7D6B" stroke-width="18" stroke-linecap="round" />

        {index > 0 ? (
          <g transform={`translate(${index === 1 ? 22 : 28} 152) rotate(${index === 1 ? -8 : -2})`}>
            <rect width="36" height="56" rx="7" fill="#211A19" />
            <rect x="4" y="10" width="28" height="38" rx="5" fill="rgba(214,247,229,0.95)" />
            <rect x="7" y="14" width="22" height="4" rx="2" fill="rgba(16,185,129,0.28)" />
            {[0, 1, 2].map((row) => (
              <g transform={`translate(8 ${23 + row * 9})`}>
                <circle cx="3" cy="3" r="3" fill="rgba(16,185,129,0.16)" />
                <path d="M1 3 L3 5.2 L6 1.4" stroke="#10B981" stroke-width="1" fill="none" stroke-linecap="round" />
                <rect x="10" y="1.5" width={row === 1 ? 12 : 16} height="3" rx="1.5" fill="rgba(107,114,128,0.20)" />
              </g>
            ))}
            {index === 2 ? <text x="8" y="46" font-family="'DM Sans', sans-serif" font-size="6.5" font-weight="800" fill="#059669">₹2,400 ✓</text> : null}
          </g>
        ) : (
          <text x="34" y="36" font-family="'DM Sans', sans-serif" font-size="24" fill="rgba(120,113,108,0.55)">?</text>
        )}

        <text
          x="0"
          y="308"
          text-anchor="middle"
          font-family={lang === 'mr' ? "'Noto Sans Devanagari', sans-serif" : "'DM Sans', sans-serif"}
          font-size="12"
          font-weight="800"
          fill={index === 2 ? 'rgba(16,185,129,0.75)' : 'rgba(255,255,255,0.58)'}
        >
          {labels[index]}
        </text>
      </g>
    );
  })}

  <g opacity="0.28" stroke-dasharray="8 8" stroke-linecap="round">
    <path d="M280 150 L346 150" stroke="rgba(255,255,255,0.42)" stroke-width="2.5" />
    <path d="M530 150 L596 150" stroke="rgba(255,255,255,0.42)" stroke-width="2.5" />
  </g>
</svg>
