---
interface Props {
  lang?: 'en' | 'mr';
}

const { lang = 'en' } = Astro.props;

const inputTags =
  lang === 'mr'
    ? ['फवारणी झाली', '3 मजूर आले', '₹2,400 खर्च']
    : ['Spraying done', '3 workers came', '₹2,400 spent'];

const outputTags =
  lang === 'mr'
    ? ['काम नोंद', 'खर्च स्पष्ट', 'उद्याचे काम']
    : ['Work logged', 'Cost sorted', 'Tomorrow ready'];

const footerLeft = lang === 'mr' ? 'शेतकरी बोलतो' : 'Farmer speaks';
const footerRight = lang === 'mr' ? 'ShramSafal रचतो' : 'ShramSafal structures';
---

<svg viewBox="0 0 440 300" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto" aria-hidden="true">
  <defs>
    <linearGradient id="pf-bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#FFF9F0" />
      <stop offset="100%" stop-color="#F4F7EE" />
    </linearGradient>
    <linearGradient id="pf-card" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#FFFFFF" />
      <stop offset="100%" stop-color="#F3F8F2" />
    </linearGradient>
    <linearGradient id="pf-phone" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#E8FFF2" />
      <stop offset="100%" stop-color="#D6F7E5" />
    </linearGradient>
    <filter id="pf-shadow" x="-10%" y="-10%" width="120%" height="130%">
      <feDropShadow dx="0" dy="10" stdDeviation="10" flood-color="#173827" flood-opacity="0.12" />
    </filter>
  </defs>

  <rect x="8" y="8" width="424" height="284" rx="32" fill="url(#pf-bg)" stroke="rgba(16,185,129,0.14)" />

  <ellipse cx="98" cy="144" rx="106" ry="30" fill="rgba(28,25,23,0.06)" />
  <path d="M0 148 C48 138 92 138 148 148" stroke="rgba(156, 163, 175, 0.45)" stroke-width="10" stroke-linecap="round" />

  <g filter="url(#pf-shadow)">
    <path d="M82 150 C116 150 148 150 176 154" stroke="#A97C53" stroke-width="34" stroke-linecap="round" />
    <path d="M175 152 C184 152 188 156 188 164" stroke="#8D6847" stroke-width="13" stroke-linecap="round" />
  </g>

  {inputTags.map((label, index) => (
    <g transform={`translate(${32 + (index % 2) * 10}, ${58 + index * 80})`}>
      <rect width={index === 1 ? 92 : 108} height="26" rx="13" fill="#FFF5DF" stroke="rgba(245,158,11,0.18)" />
      <text
        x="18"
        y="17"
        font-family={lang === 'mr' ? "'Noto Sans Devanagari', sans-serif" : "'DM Sans', sans-serif"}
        font-size="8.5"
        fill="rgba(90,72,49,0.74)"
        font-weight="700"
      >
        {label}
      </text>
    </g>
  ))}

  <g stroke-dasharray="6 6" stroke-linecap="round">
    <path d="M125 95 C168 98 194 110 214 122" stroke="rgba(143,143,143,0.38)" stroke-width="2.5" />
    <path d="M125 175 C168 172 194 160 214 148" stroke="rgba(143,143,143,0.38)" stroke-width="2.5" />
  </g>

  <g transform="translate(206 84)" filter="url(#pf-shadow)">
    <rect width="74" height="118" rx="18" fill="#221B1B" />
    <rect x="9" y="18" width="56" height="80" rx="10" fill="url(#pf-phone)" />
    <rect x="24" y="8" width="26" height="8" rx="4" fill="rgba(255,255,255,0.08)" />
    <rect x="11" y="24" width="52" height="10" rx="5" fill="rgba(16,185,129,0.18)" />
    <text x="20" y="31" font-family="'DM Sans', sans-serif" font-size="6.5" font-weight="800" fill="#059669">ShramSafal</text>
    <g transform="translate(16 44)">
      {[0, 1, 2].map((row) => (
        <g transform={`translate(0 ${row * 16})`}>
          <circle cx="5" cy="5" r="5" fill="rgba(16,185,129,0.16)" />
          <path d="M3 5 L5 7.2 L8.5 2.8" stroke="#059669" stroke-width="1.4" fill="none" stroke-linecap="round" />
          <rect x="16" y="2" width={row === 1 ? 24 : 30} height="5" rx="2.5" fill="rgba(107,114,128,0.24)" />
        </g>
      ))}
    </g>
    <rect x="15" y="78" width="44" height="18" rx="5" fill="rgba(16,185,129,0.12)" />
    <text x="22" y="89.5" font-family="'DM Sans', sans-serif" font-size="7.5" font-weight="800" fill="#059669">₹2,400 ✓</text>
  </g>

  <g stroke-dasharray="6 6" stroke-linecap="round">
    <path d="M286 122 C306 104 326 90 348 82" stroke="rgba(16,185,129,0.24)" stroke-width="2.5" />
    <path d="M286 146 C316 146 330 150 348 162" stroke="rgba(16,185,129,0.24)" stroke-width="2.5" />
    <path d="M286 170 C308 190 326 204 348 220" stroke="rgba(16,185,129,0.24)" stroke-width="2.5" />
  </g>

  {outputTags.map((label, index) => (
    <g transform={`translate(${326 + index * 8}, ${48 + index * 74})`} filter="url(#pf-shadow)">
      <rect width={index === 1 ? 96 : 110} height="28" rx="14" fill="#F3FFF7" stroke="rgba(16,185,129,0.22)" />
      <circle cx="15" cy="14" r="7" fill="rgba(16,185,129,0.14)" />
      <path d="M12.5 14 L15 16.5 L19 10.5" stroke="#10B981" stroke-width="1.6" fill="none" stroke-linecap="round" />
      <text
        x="28"
        y="18"
        font-family={lang === 'mr' ? "'Noto Sans Devanagari', sans-serif" : "'DM Sans', sans-serif"}
        font-size="8.8"
        fill="#059669"
        font-weight="800"
      >
        {label}
      </text>
    </g>
  ))}

  <g opacity="0.74">
    <circle cx="36" cy="26" r="6" fill="#F7B226" />
    <circle cx="49" cy="30" r="6" fill="#F87171" />
    <path d="M44 31 L43 46" stroke="#8D6847" stroke-width="2.2" stroke-linecap="round" />
    <circle cx="286" cy="30" r="4.5" fill="rgba(245,158,11,0.35)" />
    <circle cx="296" cy="210" r="5.5" fill="rgba(16,185,129,0.22)" />
  </g>

  <text x="70" y="268" font-family={lang === 'mr' ? "'Noto Sans Devanagari', sans-serif" : "'DM Sans', sans-serif"} font-size="9" fill="rgba(90,72,49,0.56)" font-weight="700">{footerLeft}</text>
  <text x="278" y="268" font-family={lang === 'mr' ? "'Noto Sans Devanagari', sans-serif" : "'DM Sans', sans-serif"} font-size="9" fill="rgba(5,150,105,0.58)" font-weight="800">{footerRight}</text>
</svg>
