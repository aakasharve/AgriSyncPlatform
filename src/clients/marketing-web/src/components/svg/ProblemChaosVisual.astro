<svg viewBox="0 0 600 400" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto" aria-hidden="true">
  <defs>
    <filter id="cs-shd" x="-8%" y="-8%" width="116%" height="116%">
      <feDropShadow dx="0" dy="1" stdDeviation="2" flood-color="#3D2B1F" flood-opacity="0.08"/>
    </filter>
  </defs>

  <!-- Real mental load fragments scattered — not magical, just daily farm chaos -->

  <!-- EXPENSE NOTE 1 — crumpled, tilted -->
  <g transform="translate(40, 50) rotate(-18)" filter="url(#cs-shd)" class="drift-slow">
    <path d="M0,2 L58,0 L60,72 L2,75 Z" fill="#FFFBF0" stroke="#D6CFBF" stroke-width="0.8"/>
    <text x="8" y="16" font-family="'Noto Sans Devanagari', sans-serif" font-size="9" fill="#5C4A3A" font-weight="600">खर्च पत्र</text>
    <line x1="8" y1="24" x2="48" y2="24" stroke="#D6CFBF" stroke-width="0.5"/>
    <text x="8" y="36" font-family="'Noto Sans Devanagari', sans-serif" font-size="8" fill="#8B7D6B">DAP — ₹1,400</text>
    <text x="8" y="48" font-family="'Noto Sans Devanagari', sans-serif" font-size="8" fill="#8B7D6B">मजूर — ₹???</text>
    <text x="8" y="60" font-family="'Noto Sans Devanagari', sans-serif" font-size="8" fill="#B91C1C" opacity="0.5">एकूण ??</text>
  </g>

  <!-- WORKER TALLY — rough paper -->
  <g transform="translate(420, 20) rotate(12)" filter="url(#cs-shd)" class="drift">
    <rect width="65" height="55" rx="2" fill="#FFFBF0" stroke="#D6CFBF" stroke-width="0.8"/>
    <text x="6" y="14" font-family="'Noto Sans Devanagari', sans-serif" font-size="8" fill="#5C4A3A" font-weight="600">मजूर</text>
    <!-- Tally marks -->
    <g transform="translate(6, 20)">
      <line x1="0" y1="0" x2="0" y2="12" stroke="#5C4A3A" stroke-width="1.5"/>
      <line x1="5" y1="0" x2="5" y2="12" stroke="#5C4A3A" stroke-width="1.5"/>
      <line x1="10" y1="0" x2="10" y2="12" stroke="#5C4A3A" stroke-width="1.5"/>
      <line x1="-2" y1="6" x2="12" y2="6" stroke="#5C4A3A" stroke-width="1.2"/>
      <line x1="18" y1="0" x2="18" y2="12" stroke="#5C4A3A" stroke-width="1.5"/>
      <line x1="23" y1="0" x2="23" y2="12" stroke="#5C4A3A" stroke-width="1.5"/>
    </g>
    <text x="6" y="44" font-family="'Noto Sans Devanagari', sans-serif" font-size="7" fill="#8B7D6B">= 7? 8?</text>
    <!-- Cross-out -->
    <line x1="30" y1="40" x2="55" y2="48" stroke="#B91C1C" stroke-width="0.5" opacity="0.4"/>
  </g>

  <!-- PHONE with missed calls -->
  <g transform="translate(240, 30) rotate(-5)" filter="url(#cs-shd)" class="drift-reverse">
    <rect width="40" height="65" rx="6" fill="#1C1917" opacity="0.85"/>
    <rect x="3" y="9" width="34" height="47" rx="3" fill="#FEE2E2"/>
    <!-- Missed call icon -->
    <g transform="translate(8, 18)">
      <path d="M0,10 C0,6 4,2 10,2 C16,2 20,6 20,10" stroke="#B91C1C" stroke-width="1.5" fill="none"/>
      <path d="M3,8 L0,12 L6,10" stroke="#B91C1C" stroke-width="1" fill="none"/>
    </g>
    <text x="6" y="40" font-family="'DM Sans', sans-serif" font-size="7" fill="#B91C1C" font-weight="600">3 missed</text>
    <text x="6" y="50" font-family="'Noto Sans Devanagari', sans-serif" font-size="6" fill="#8B7D6B">मुकादम</text>
  </g>

  <!-- CLOCK — time pressure -->
  <g transform="translate(520, 160)" class="drift-slow">
    <circle cx="30" cy="30" r="28" fill="none" stroke="#8B7D6B" stroke-width="1.5" opacity="0.3"/>
    <circle cx="30" cy="30" r="25" fill="#FFFBF0" opacity="0.5"/>
    <line x1="30" y1="6" x2="30" y2="10" stroke="#8B7D6B" stroke-width="1" opacity="0.4"/>
    <line x1="30" y1="50" x2="30" y2="54" stroke="#8B7D6B" stroke-width="1" opacity="0.4"/>
    <line x1="6" y1="30" x2="10" y2="30" stroke="#8B7D6B" stroke-width="1" opacity="0.4"/>
    <line x1="50" y1="30" x2="54" y2="30" stroke="#8B7D6B" stroke-width="1" opacity="0.4"/>
    <line x1="30" y1="30" x2="30" y2="12" stroke="#5C4A3A" stroke-width="1.5"/>
    <line x1="30" y1="30" x2="44" y2="24" stroke="#5C4A3A" stroke-width="1"/>
    <circle cx="30" cy="30" r="2" fill="#5C4A3A"/>
  </g>

  <!-- RUPEE NOTES scattered -->
  <g transform="translate(130, 260) rotate(25)" filter="url(#cs-shd)" class="drift">
    <rect width="60" height="30" rx="2" fill="#D6CFBF" stroke="#A0926B" stroke-width="0.6"/>
    <text x="6" y="14" font-family="'DM Sans', sans-serif" font-size="7" fill="#5C4A3A">₹500</text>
    <circle cx="48" cy="15" r="8" fill="none" stroke="#A0926B" stroke-width="0.5" opacity="0.4"/>
  </g>
  <g transform="translate(340, 290) rotate(-15)" filter="url(#cs-shd)" class="drift-reverse">
    <rect width="55" height="28" rx="2" fill="#D6CFBF" stroke="#A0926B" stroke-width="0.6"/>
    <text x="6" y="13" font-family="'DM Sans', sans-serif" font-size="7" fill="#5C4A3A">₹200</text>
    <circle cx="42" cy="14" r="7" fill="none" stroke="#A0926B" stroke-width="0.5" opacity="0.4"/>
  </g>

  <!-- FERTILIZER BAG fragment -->
  <g transform="translate(460, 280) rotate(8)" filter="url(#cs-shd)" class="drift-slow">
    <rect width="55" height="40" rx="3" fill="#E8E2D6" stroke="#A0926B" stroke-width="0.8"/>
    <text x="6" y="14" font-family="'DM Sans', sans-serif" font-size="7" fill="#5C4A3A" font-weight="600">DAP</text>
    <text x="6" y="26" font-family="'Noto Sans Devanagari', sans-serif" font-size="6" fill="#8B7D6B">50kg बॅग</text>
    <text x="6" y="36" font-family="'Noto Sans Devanagari', sans-serif" font-size="6" fill="#8B7D6B" opacity="0.6">किती लागले?</text>
  </g>

  <!-- TASK SLIP — spray pending -->
  <g transform="translate(80, 170) rotate(-8)" filter="url(#cs-shd)" class="drift-reverse">
    <rect width="70" height="45" rx="2" fill="#FFFBF0" stroke="#D6CFBF" stroke-width="0.8"/>
    <text x="6" y="14" font-family="'Noto Sans Devanagari', sans-serif" font-size="7" fill="#5C4A3A" font-weight="600">उद्या करायचे</text>
    <text x="6" y="26" font-family="'Noto Sans Devanagari', sans-serif" font-size="7" fill="#8B7D6B">□ प्लॉट B फवारणी</text>
    <text x="6" y="38" font-family="'Noto Sans Devanagari', sans-serif" font-size="7" fill="#8B7D6B">□ ठिबक चेक</text>
  </g>

  <!-- WATER TIMING fragment -->
  <g transform="translate(300, 170) rotate(6)" filter="url(#cs-shd)" class="drift">
    <rect width="65" height="35" rx="2" fill="#FFFBF0" stroke="#D6CFBF" stroke-width="0.8"/>
    <text x="6" y="14" font-family="'Noto Sans Devanagari', sans-serif" font-size="7" fill="#5C4A3A">पाणी वेळ</text>
    <text x="6" y="26" font-family="'Noto Sans Devanagari', sans-serif" font-size="7" fill="#B91C1C" opacity="0.6">कधी दिले? विसरलो</text>
  </g>

  <!-- Scattered question marks — mental confusion -->
  <g opacity="0.15">
    <text x="200" y="80" font-family="'Noto Serif Devanagari', serif" font-size="24" fill="#8B7D6B">?</text>
    <text x="380" y="130" font-family="'Noto Serif Devanagari', serif" font-size="18" fill="#8B7D6B">?</text>
    <text x="560" y="340" font-family="'Noto Serif Devanagari', serif" font-size="20" fill="#8B7D6B">?</text>
    <text x="30" y="350" font-family="'Noto Serif Devanagari', serif" font-size="16" fill="#8B7D6B">?</text>
    <text x="490" y="80" font-family="'Noto Serif Devanagari', serif" font-size="14" fill="#8B7D6B">?</text>
  </g>

  <!-- Subtle connecting lines -->
  <g opacity="0.06">
    <line x1="100" y1="120" x2="260" y2="70" stroke="#8B7D6B" stroke-width="1" stroke-dasharray="4 4"/>
    <line x1="300" y1="200" x2="450" y2="50" stroke="#8B7D6B" stroke-width="1" stroke-dasharray="4 4"/>
    <line x1="150" y1="300" x2="360" y2="310" stroke="#8B7D6B" stroke-width="1" stroke-dasharray="4 4"/>
  </g>
</svg>
