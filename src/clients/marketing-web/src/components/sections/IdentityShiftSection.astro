---
import { getLangFromUrl, getTranslations } from '../../i18n/translations';
import IdentityJourneySvg from '../svg/IdentityJourneySvg.astro';

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
---

<section
  data-scene="identity-shift"
  data-soil="alluvial"
  data-cursor="sun"
  class="relative py-section overflow-hidden"
  style="background:var(--bg-surface);"
>
  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 70% 50% at 50% 20%, rgba(20,83,45,0.07) 0%, transparent 50%), radial-gradient(ellipse 52% 34% at 78% 84%, rgba(146,64,14,0.07) 0%, transparent 46%);" aria-hidden="true"></div>

  <div class="relative z-10 max-w-site mx-auto px-5 md:px-8 text-center">
    <span class="chapter-mark" data-chapter>
      {lang === 'mr' ? 'Chapter 09 · कोण बनतो' : 'Chapter 09 · Who You Become'}
    </span>

    <h2
      class="font-serif text-h2 mb-6"
      style="color:var(--text-primary);"
      set:html={t.identity_shift.headline.replace(/\n/g, '<br />')}
    />

    <p class="text-body-lg max-w-prose mx-auto mb-10" style="color:var(--text-secondary);">
      {t.identity_shift.body}
    </p>

    <div class="rounded-[2rem] p-4 md:p-6 shadow-[0_24px_60px_rgba(146,64,14,0.08)]" style="background:var(--bg-elevated);border:1px solid var(--border-light);">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
        {[
          'identity-state-01-observing.png',
          'identity-state-02-burdened.png',
          'identity-state-03-recording.png',
          'identity-state-04-confident.png',
        ].map((img, i) => (
          <div class="relative rounded-2xl overflow-hidden border group" style="background:var(--bg-surface);border-color:var(--border-light);">
            <img
              src={`/images/characters/${img}`}
              alt={
                lang === 'mr'
                  ? ['शेत निरीक्षण करणारा शेतकरी','कागदपत्रांच्या ओझ्याखाली शेतकरी','नोंद करणारा शेतकरी','आत्मविश्वासू शेतकरी'][i]
                  : ['Farmer observing his field at dawn','Farmer burdened by scattered paperwork','Farmer recording the day by voice','Confident farmer with clear records'][i]
              }
              class="w-full h-auto object-cover transition-transform duration-700 group-hover:scale-[1.03]"
              style="mix-blend-mode:multiply;opacity:0.95;"
            />
          </div>
        ))}
      </div>
    </div>

    <div class="max-w-3xl mx-auto mt-10 grid grid-cols-1 md:grid-cols-2 gap-4" data-reveal-3d-group>
      {t.identity_shift.lines.map((line: string, i: number) => (
        <div
          class="card-white rounded-2xl px-5 py-5 text-left shadow-[0_12px_32px_rgba(146,64,14,0.07)]"
          data-reveal-3d-item
        >
          <div class="flex items-center gap-3 mb-3">
            <span class="inline-flex items-center justify-center w-8 h-8 rounded-full text-sm font-bold text-white" style={`background:${i % 2 === 0 ? '#14532D' : '#92400E'}`}>
              {i + 1}
            </span>
            <div class="h-px flex-1" style={`background:${i % 2 === 0 ? 'rgba(20,83,45,0.22)' : 'rgba(146,64,14,0.22)'}`}></div>
          </div>
          <p class="text-base md:text-lg leading-7 font-medium" style="color:var(--text-primary);">{line}</p>
        </div>
      ))}
    </div>
  </div>
</section>
