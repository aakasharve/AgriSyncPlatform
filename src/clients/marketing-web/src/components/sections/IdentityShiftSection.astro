---
import { getLangFromUrl, getTranslations } from '../../i18n/translations';
import IdentityJourneySvg from '../svg/IdentityJourneySvg.astro';

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
---

<section
  data-scene="identity-shift"
  class="relative py-section overflow-hidden"
>
  <div class="absolute inset-0" style="background:var(--bg-surface);"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_30%_20%,rgba(216,155,29,0.12),transparent_50%),radial-gradient(ellipse_at_70%_80%,rgba(5,150,105,0.08),transparent_45%)]"></div>
  <div class="absolute inset-0 grain pointer-events-none"></div>

  <!-- Top wave divider -->
  <div class="absolute top-0 left-0 right-0 z-10 rotate-180">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto block" preserveAspectRatio="none">
      <path d="M0 35C360 5 720 55 1080 25C1260 10 1380 30 1440 35V60H0V35Z" fill="var(--bg-base, #0D1A12)"/>
    </svg>
  </div>

  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <div class="ambient-particle gold-particle" style="left: 12%; animation-delay: 0s; animation-duration: 11s;"></div>
    <div class="ambient-particle gold-particle" style="left: 30%; animation-delay: 3s; animation-duration: 14s;"></div>
    <div class="ambient-particle gold-particle" style="left: 55%; animation-delay: 1.5s; animation-duration: 12s;"></div>
    <div class="ambient-particle gold-particle" style="left: 75%; animation-delay: 4s; animation-duration: 13s;"></div>
    <div class="ambient-particle gold-particle" style="left: 90%; animation-delay: 2s; animation-duration: 10s;"></div>
  </div>

  <!-- Bottom wave divider -->
  <div class="absolute bottom-0 left-0 right-0 z-10">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto block" preserveAspectRatio="none">
      <path d="M0 30C240 10 480 50 720 25C960 0 1200 40 1440 30V60H0V30Z" fill="var(--bg-base, #0D1A12)"/>
    </svg>
  </div>

  <div class="relative z-10 max-w-site mx-auto px-5 md:px-8 text-center">
    <span class="chapter-mark" data-chapter>
      {lang === 'mr' ? 'Chapter 08 · परिवर्तन' : 'Chapter 08 · Identity Shift'}
    </span>
    <h2
      class="scene-stagger font-serif text-h2 text-white mb-6 md:mb-8"
      set:html={t.identity_shift.headline.replace(/\n/g, '<br />')}
    />
    <p class="scene-stagger text-body-lg text-white/75 max-w-prose mx-auto mb-8 md:mb-10">
      {t.identity_shift.body}
    </p>

    <div class="scene-stagger mb-8 md:mb-10">
      <div class="w-full max-w-4xl mx-auto">
        <IdentityJourneySvg />
      </div>
    </div>

    <div class="max-w-2xl mx-auto space-y-5 md:space-y-6" data-reveal-3d-group>
      {t.identity_shift.lines.map((line: string, i: number) => (
        <div
          class="identity-line flex items-center gap-4 text-left"
          style={`--line-delay: ${i * 0.2}s;`}
          data-reveal-3d-item
        >
          <div class="flex-shrink-0 flex flex-col items-center">
            <div class:list={[
              'w-3 h-3 rounded-full border-2',
              i === t.identity_shift.lines.length - 1
                ? 'bg-brand border-brand scale-125'
                : 'bg-white/20 border-white/40',
            ]}></div>
            {i < t.identity_shift.lines.length - 1 && (
              <div class="w-px h-5 md:h-6 bg-white/20 mt-1"></div>
            )}
          </div>
          <p class:list={[
            'text-base md:text-lg leading-relaxed',
            i === t.identity_shift.lines.length - 1
              ? 'text-white font-bold'
              : 'text-white/80 font-medium',
          ]}>{line}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .identity-line {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.5s ease-out, transform 0.5s ease-out;
    transition-delay: var(--line-delay, 0s);
  }

  [data-scene="identity-shift"].scene-visible .identity-line {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .identity-line {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>
