---
import { getLangFromUrl, getTranslations } from '../../i18n/translations';

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
---

<section
  data-scene="clarity"
  class="relative py-section overflow-hidden"
>
  <div class="absolute inset-0" style="background:var(--bg-surface);"></div>

  <div class="relative z-10 max-w-site mx-auto px-5 md:px-8">
    <div class="text-center mb-8 md:mb-10">
      <span class="chapter-mark" data-chapter>
        {lang === 'mr' ? 'Chapter 06 · स्पष्टता' : 'Chapter 06 · Clarity'}
      </span>
      <h2
        class="scene-stagger font-serif text-h2 mb-6"
        style="color:var(--white-70);"
        set:html={t.scene6.headline.replace(/\n/g, '<br />')}
      />
      <p class="scene-stagger text-body-lg max-w-prose mx-auto" style="color:var(--white-40);">
        {t.scene6.body}
      </p>
    </div>

    <!-- Code-Based Dashboard Mockup (Premium UI) -->
    <div class="scene-stagger max-w-sm mx-auto mb-10 md:mb-12">
      <div class="relative mx-auto w-full max-w-[320px] md:max-w-[350px] rounded-[2.5rem] border-[8px] p-1.5 shadow-[0_32px_80px_-12px_rgba(5,150,105,0.2)] transform hover:-translate-y-2 transition-transform duration-500" style="border-color:rgba(255,255,255,0.06);background:var(--bg-elevated);">
        <!-- Phone screen -->
        <div class="relative w-full rounded-[2rem] overflow-hidden shadow-inner h-[500px]" style="background:var(--bg-base);">
          <!-- Header -->
          <div class="bg-gradient-to-r from-brand to-brand-fresh px-6 pt-10 pb-6 rounded-b-[1.5rem] shadow-sm relative overflow-hidden">
            <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMSIgY3k9IjEiIHI9IjEiIGZpbGw9InJnYmEoMjU1LDI1NSwyNTUsMC4xNSkiLz48L3N2Zz4=')] opacity-30"></div>
            <div class="relative z-10">
              <h3 class="text-white font-serif font-bold text-2xl tracking-tight drop-shadow-sm">ShramSafal</h3>
              <p class="text-white/90 text-sm mt-1.5 font-medium">Farm Overview <span class="opacity-50 mx-1">•</span> Today</p>
            </div>
          </div>
          
          <!-- Body -->
          <div class="p-5 space-y-4">
            <!-- Today's Work -->
            <div class="card-dark p-4 rounded-xl hover:border-brand/30 transition-colors">
              <h4 class="text-[11px] font-bold uppercase tracking-widest mb-3 flex items-center gap-2" style="color:var(--white-40);">
                <span class="w-1.5 h-1.5 rounded-full bg-brand"></span> Today's Work
              </h4>
              <div class="space-y-3">
                <div class="flex items-center gap-3">
                  <div class="w-5 h-5 rounded-md bg-brand/10 flex items-center justify-center flex-shrink-0" style="color:var(--brand-fresh);">✓</div>
                  <span class="text-sm font-bold" style="color:var(--white-70);">Spraying • Plot A</span>
                </div>
                <div class="flex items-center gap-3">
                  <div class="w-5 h-5 rounded-md bg-brand flex items-center justify-center flex-shrink-0 text-white">✓</div>
                  <span class="text-sm font-bold" style="color:var(--white-70);">Irrigation • 2 hrs</span>
                </div>
              </div>
            </div>

            <!-- Costs -->
            <div class="card-dark p-4 rounded-xl hover:shadow-md transition-shadow relative overflow-hidden" style="background:linear-gradient(135deg,rgba(251,191,36,0.08),rgba(217,119,6,0.04));">
               <div class="absolute -right-4 -top-4 w-16 h-16 bg-amber-400/10 rounded-full blur-xl"></div>
              <h4 class="text-[11px] font-bold text-amber-400 uppercase tracking-widest mb-2 relative z-10">Costs Recorded</h4>
              <div class="flex items-baseline gap-1 relative z-10">
                <span class="text-amber-400 font-extrabold text-xl">₹</span>
                <span class="text-3xl font-black text-amber-400 tabular-nums tracking-tight">2,400</span>
              </div>
              <p class="text-xs text-amber-400/60 mt-1 font-medium relative z-10">For 3 workers (Plot A)</p>
            </div>

            <!-- Tomorrow -->
            <div class="card-dark p-4 rounded-xl border-l-[3px] border-l-blue-400">
              <h4 class="text-[11px] font-bold uppercase tracking-widest mb-2 opacity-70" style="color:var(--white-40);">Tomorrow's Plan</h4>
              <p class="text-sm font-bold" style="color:var(--white-70);">Fertilizer • Plot B</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      <div class="clarity-card scene-stagger card-dark rounded-xl p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border-l-4 border-l-brand relative overflow-hidden">
        <div class="w-10 h-10 rounded-lg bg-brand/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5" style="color:var(--brand-fresh);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
          </svg>
        </div>
        <h3 class="font-serif text-xl md:text-2xl mb-4 font-bold" style="color:var(--white-70);">{t.scene6.card1_title}</h3>
        <ul class="space-y-3">
          {t.scene6.card1_items.map((item: string) => (
            <li class="flex items-start gap-2 text-base" style="color:var(--white-40);">
              <svg class="w-4 h-4 mt-0.5 flex-shrink-0" style="color:var(--brand-fresh);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>
        <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-brand/20 to-transparent"></div>
      </div>

      <div class="clarity-card scene-stagger card-dark rounded-xl p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border-l-4 border-l-brand relative overflow-hidden">
        <div class="w-10 h-10 rounded-lg bg-amber-50/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33" />
          </svg>
        </div>
        <h3 class="font-serif text-xl md:text-2xl mb-4 font-bold" style="color:var(--white-70);">{t.scene6.card2_title}</h3>
        <ul class="space-y-3">
          {t.scene6.card2_items.map((item: string) => (
            <li class="flex items-center justify-between text-base">
              <span style="color:var(--white-40);">{item.split('|')[0]}</span>
              <span class="font-bold tabular-nums" style="color:var(--white-70);">{item.split('|')[1]}</span>
            </li>
          ))}
        </ul>
        <div class="mt-3 pt-3 border-t-2 border-brand/20 flex items-center justify-between text-base">
          <span class="font-bold" style="color:var(--white-70);">{t.scene6.card2_total_label}</span>
          <span class="font-bold text-base tabular-nums" style="color:var(--brand-fresh);">{t.scene6.card2_total}</span>
        </div>
        <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-amber-200/20 to-transparent"></div>
      </div>

      <div class="clarity-card scene-stagger card-dark rounded-xl p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border-l-4 border-l-accent-harvest relative overflow-hidden">
        <div class="w-10 h-10 rounded-lg bg-amber-50/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-accent-harvest" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
          </svg>
        </div>
        <h3 class="font-serif text-xl md:text-2xl mb-4 font-bold" style="color:var(--white-70);">{t.scene6.card3_title}</h3>
        <ul class="space-y-3">
          {t.scene6.card3_items.map((item: string) => (
            <li class="flex items-start gap-2 text-base" style="color:var(--white-40);">
              <svg class="w-4 h-4 text-accent-harvest mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
              </svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>
        <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-accent-harvest/20 to-transparent"></div>
      </div>
    </div>
  </div>
</section>
