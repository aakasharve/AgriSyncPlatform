---
import { getLangFromUrl, getTranslations } from '../../i18n/translations';
import WaitlistForm from '../islands/WaitlistForm.tsx';
import GoldenHorizon from '../svg/GoldenHorizon.astro';
import CropSilhouette from '../svg/CropSilhouette.astro';

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
---

<section
  data-scene="cta"
  data-soil="moonlit"
  data-cursor="pen"
  class="relative py-section overflow-hidden"
>
  <!-- CTA is the "end of day" dark close — soil black, not forest black -->
  <div class="absolute inset-0" style="background:linear-gradient(180deg, #1A0F00 0%, #120B00 60%, #0A0600 100%);"></div>
  <div
    class="absolute inset-0 pointer-events-none"
    aria-hidden="true"
    style="background:
      radial-gradient(ellipse 65% 45% at 18% 20%, rgba(20,83,45,0.10) 0%, transparent 50%),
      radial-gradient(ellipse 58% 40% at 78% 82%, rgba(217,119,6,0.10) 0%, transparent 52%),
      radial-gradient(circle at 50% 14%, rgba(255,255,255,0.10) 0 1px, transparent 1px),
      radial-gradient(circle at 20% 34%, rgba(255,255,255,0.14) 0 1px, transparent 1px),
      radial-gradient(circle at 76% 18%, rgba(255,255,255,0.10) 0 1px, transparent 1px),
      radial-gradient(circle at 64% 52%, rgba(255,255,255,0.08) 0 1px, transparent 1px),
      radial-gradient(circle at 30% 64%, rgba(255,255,255,0.08) 0 1px, transparent 1px);"
  ></div>

  <GoldenHorizon dots={true} class="absolute top-0 left-0 right-0" />
  <CropSilhouette count={18} variant="mixed" goldGlow={true} height={78} />

  <div class="relative z-10 max-w-site mx-auto px-5 md:px-8">
    <div class="grid grid-cols-1 xl:grid-cols-[1.1fr_0.9fr] gap-8 items-start">
      <div class="pt-4">
        <span class="chapter-mark" data-chapter>
          {lang === 'mr' ? 'Chapter 11 · सुरुवात' : 'Chapter 11 · Begin'}
        </span>

        <h2 class="font-serif text-[clamp(2.3rem,5.4vw,4.6rem)] text-white font-bold tracking-tight leading-[1.04]" data-split-headline>
          {t.scene8.cta_headline}
        </h2>

        <p class="mt-5 max-w-prose text-[clamp(1rem,1.5vw,1.08rem)] leading-8" style="color:var(--white-55);">
          {t.scene8.cta_body}
        </p>

        <p class="mt-5 text-sm md:text-base italic" style="color:var(--white-40);">
          {t.scene8.trust_note}
        </p>

        <div class="mt-10 grid grid-cols-1 sm:grid-cols-2 gap-4" data-reveal-3d-group>
          {t.scene8.future_items.map((item: string, index: number) => (
            <div
              class="card-dark rounded-2xl p-5 md:p-6 border border-white/8 relative overflow-hidden"
              data-reveal-3d-item
            >
              <div class="absolute inset-x-0 top-0 h-px" style={`background:${index % 2 === 0 ? 'linear-gradient(90deg, rgba(16,185,129,0.65), transparent)' : 'linear-gradient(90deg, rgba(245,158,11,0.65), transparent)'}`}></div>
              <div class="text-[0.68rem] font-extrabold uppercase tracking-[0.28em] mb-3" style="color:var(--gold);">
                {lang === 'mr' ? `टप्पा 0${index + 1}` : `Stage 0${index + 1}`}
              </div>
              <p class="text-base md:text-lg leading-7 font-medium text-white">{item}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="relative xl:pt-8" data-zoom-section data-zoom-from-scale="0.92" data-zoom-from-y="40">
        <div class="absolute -inset-4 rounded-[2rem] pointer-events-none" style="background:radial-gradient(ellipse at center, rgba(16,185,129,0.16) 0%, transparent 68%);filter:blur(24px);" aria-hidden="true"></div>
        <div class="relative rounded-[2rem] border border-white/10 bg-[linear-gradient(180deg,rgba(255,255,255,0.08),rgba(255,255,255,0.03))] backdrop-blur-xl p-5 md:p-6 shadow-[0_28px_80px_rgba(0,0,0,0.35)]">
          <div class="flex items-start justify-between gap-4 mb-6">
            <div>
              <div class="text-[0.68rem] font-extrabold uppercase tracking-[0.28em]" style="color:var(--gold);">
                {lang === 'mr' ? 'लवकर प्रवेश' : 'Early access'}
              </div>
              <h3 class="mt-2 font-serif text-3xl text-white font-bold">{t.waitlist.title}</h3>
            </div>
            <div class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[0.7rem] font-bold uppercase tracking-[0.24em]" style="color:var(--brand-fresh);">
              {lang === 'mr' ? 'लाईव्ह लवकरच' : 'Soon live'}
            </div>
          </div>

          <div class="rounded-[1.5rem] border border-white/10 bg-[rgba(6,15,7,0.62)] p-3 md:p-4">
            <WaitlistForm
              client:idle
              lang={lang as 'en' | 'mr'}
              translations={t.waitlist}
            />
          </div>

          <div class="mt-5 flex flex-wrap items-center gap-3 text-sm" style="color:var(--white-40);">
            <span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-1.5">
              <span class="w-2 h-2 rounded-full bg-brand"></span>
              {lang === 'mr' ? 'टायपिंग नाही' : 'No typing'}
            </span>
            <span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-1.5">
              <span class="w-2 h-2 rounded-full" style="background:var(--gold);"></span>
              {lang === 'mr' ? 'रोज 1 मिनिट' : '1 minute daily'}
            </span>
            <span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-1.5">
              <span class="w-2 h-2 rounded-full" style="background:var(--farm-sky);"></span>
              {lang === 'mr' ? 'ऑफलाइन' : 'Offline'}
            </span>
          </div>

          <div class="mt-6 pt-5 border-t border-white/8 flex flex-wrap items-center gap-2 text-sm" style="color:var(--white-40);">
            <span>{t.scene8.whatsapp_prefix}</span>
            <a
              href="https://wa.me/919999999999"
              target="_blank"
              rel="noopener noreferrer"
              class="font-bold transition-colors hover:text-white"
              style="color:var(--brand-fresh);"
            >
              WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
