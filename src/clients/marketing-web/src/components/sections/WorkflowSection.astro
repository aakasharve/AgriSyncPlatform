---
import { getLangFromUrl, getTranslations } from '../../i18n/translations';
import PartnerFlowVisual from '../svg/PartnerFlowVisual.astro';

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);

const stageLabels =
  lang === 'mr'
    ? [
        { title: 'तुम्ही बोला', body: 'जसं घडलं तसं बोला. प्लॉट, खर्च, मजूर, बाकी काम — ज्या भाषेत जमतं त्या भाषेत.' },
        { title: 'फोन पकडतो', body: 'रॉ बोलणं हरवत नाही. ते नोंदीत बसवण्यासाठी पकडलं जातं.' },
        { title: 'नोंद वेगळी होते', body: 'काम, खर्च, वेळ आणि बाकी काम वेगळं दिसायला लागतं. उद्याचं काय ते लगेच समजतं.' },
      ]
    : [
        { title: 'You speak', body: 'Say the day as it happened. Plot, labour, spend, pending work — in plain speech, not form language.' },
        { title: 'The phone catches it', body: 'The raw voice does not get lost. It is captured first, then structured into a useful record.' },
        { title: 'The record gets sorted', body: 'Work, cost, time, and pending tasks stop sitting in one blur. Tomorrow becomes visible.' },
      ];
---

<section
  data-scene="workflow"
  data-soil="wet-irrigated"
  data-cursor="mic"
  class="relative py-section overflow-hidden"
  style="background:var(--bg-surface);"
>
  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 72% 50% at 50% 10%, rgba(217,119,6,0.08) 0%, transparent 46%), radial-gradient(ellipse 52% 36% at 82% 72%, rgba(20,83,45,0.07) 0%, transparent 50%);" aria-hidden="true"></div>

  <div class="relative z-10 max-w-site mx-auto px-5 md:px-8">
    <div class="max-w-3xl mx-auto text-center mb-10">
      <span class="chapter-mark" data-chapter>
        {lang === 'mr' ? 'Chapter 04 · बोला आणि नोंद तयार' : 'Chapter 04 · Speak and We Sort'}
      </span>
      <h2 class="font-serif text-h2 mb-6" style="color:rgb(29,51,38);">
        {t.transcript.headline}
      </h2>
      <p class="text-body-lg max-w-prose mx-auto" style="color:rgba(29,51,38,0.74);">
        {t.transcript.body}
      </p>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-[0.9fr_1.1fr] gap-8 items-start">
      <div class="space-y-4 xl:sticky xl:top-28" data-reveal-3d-group>
        {stageLabels.map((stage, index) => (
          <div
            class="card-white rounded-2xl px-5 py-6 shadow-[0_12px_32px_rgba(146,64,14,0.07)]"
            data-reveal-3d-item
          >
            <div class="flex items-center gap-3 mb-4">
              <span class="inline-flex items-center justify-center w-9 h-9 rounded-full text-sm font-black text-white" style={`background:${index === 1 ? '#14532D' : '#D97706'}`}>
                0{index + 1}
              </span>
              <div class="h-px flex-1" style={`background:${index === 1 ? 'rgba(20,83,45,0.20)' : 'rgba(217,119,6,0.24)'}`}></div>
            </div>
            <h3 class="font-serif text-2xl mb-3" style="color:var(--text-primary);">{stage.title}</h3>
            <p class="text-base md:text-lg leading-7" style="color:var(--text-secondary);">{stage.body}</p>
          </div>
        ))}
      </div>

      <div class="relative">
        <img 
          src="/images/characters/workflow-speaking-farmer.png" 
          alt={lang === 'mr' ? 'शेतकरी नोंदी सांगताना' : 'Farmer recording work'} 
          class="hidden xl:block absolute -left-20 bottom-10 w-52 h-auto z-20 pointer-events-none drop-shadow-2xl" 
        />
        <div class="workflow-chip workflow-chip--input" data-parallax data-parallax-rate="10">
          {lang === 'mr' ? 'फवारणी झाली' : 'Spraying done'}
        </div>
        <div class="workflow-chip workflow-chip--input-2" data-parallax data-parallax-rate="7">
          {lang === 'mr' ? '3 मजूर आले' : '3 workers came'}
        </div>
        <div class="workflow-chip workflow-chip--output" data-parallax data-parallax-rate="4">
          {lang === 'mr' ? 'काम नोंद' : 'Work logged'}
        </div>
        <div class="workflow-chip workflow-chip--output-2" data-parallax data-parallax-rate="3">
          {lang === 'mr' ? 'खर्च स्पष्ट' : 'Cost sorted'}
        </div>

        <div class="rounded-[2rem] border border-[rgba(19,50,36,0.08)] bg-white/85 px-4 py-5 md:px-6 md:py-6 shadow-[0_24px_60px_rgba(0,0,0,0.08)]">
          <PartnerFlowVisual lang={lang} />
        </div>

        <div class="workflow-caption" data-reveal>
          {lang === 'mr'
            ? 'वर आवाज. मध्ये नोंद. खाली उद्याचा वापर. स्क्रोल करताना गोष्टी वेगळ्या आणि स्पष्ट होत जातात.'
            : 'Voice comes in on one side, structure appears in the center, and tomorrow becomes usable on the other side.'}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .workflow-chip {
    position: absolute;
    z-index: 3;
    padding: 0.6rem 1rem;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
  }

  .workflow-chip--input,
  .workflow-chip--input-2 {
    background: #FFF4DF;
    color: rgba(102, 76, 39, 0.74);
    border: 1px solid rgba(245,158,11,0.18);
  }

  .workflow-chip--output,
  .workflow-chip--output-2 {
    background: #F3FFF7;
    color: #0F8A63;
    border: 1px solid rgba(16,185,129,0.2);
  }

  .workflow-chip--input {
    left: -0.5rem;
    top: 2rem;
  }

  .workflow-chip--input-2 {
    left: 1.8rem;
    bottom: 4rem;
  }

  .workflow-chip--output {
    right: 1rem;
    top: 2.5rem;
  }

  .workflow-chip--output-2 {
    right: 0;
    bottom: 5rem;
  }

  .workflow-caption {
    max-width: 36rem;
    margin: 1.25rem auto 0;
    text-align: center;
    font-size: 1rem;
    line-height: 1.8;
    color: rgba(29,51,38,0.68);
    font-style: italic;
  }

  @media (max-width: 1023px) {
    .workflow-chip {
      position: static;
      display: inline-flex;
      margin: 0 0.5rem 0.75rem 0;
    }
  }
</style>
