---
import { getLangFromUrl, getTranslations } from '../../i18n/translations';

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
const isMr = lang === 'mr';

const stageLabels = isMr
  ? [
      { title: 'तुम्ही बोला', body: 'जसं घडलं तसं बोला. प्लॉट, खर्च, मजूर, बाकी काम — ज्या भाषेत जमतं त्या भाषेत.' },
      { title: 'फोन पकडतो', body: 'रॉ बोलणं हरवत नाही. ते नोंदीत बसवण्यासाठी पकडलं जातं.' },
      { title: 'नोंद वेगळी होते', body: 'काम, खर्च, वेळ आणि बाकी काम वेगळं दिसायला लागतं. उद्याचं काय ते लगेच समजतं.' },
    ]
  : [
      { title: 'You speak', body: 'Say the day as it happened. Plot, labour, spend, pending work — in plain speech, not form language.' },
      { title: 'The phone catches it', body: 'The raw voice does not get lost. It is captured first, then structured into a useful record.' },
      { title: 'The record gets sorted', body: 'Work, cost, time, and pending tasks stop sitting in one blur. Tomorrow becomes visible.' },
    ];

const voiceText = isMr
  ? '"फवारणी झाली. ३ मजूर आले. द्राक्ष प्लॉटवर आज ₹२,४०० खर्च."'
  : '"Spraying done. 3 workers came. ₹2,400 spent today on the grape plot."';

const inputTags  = isMr
  ? ['फवारणी झाली', '३ मजूर', '₹२,४०० खर्च']
  : ['Spraying done', '3 workers', '₹2,400'];

const outputTags = isMr
  ? ['काम नोंद', 'खर्च स्पष्ट', 'उद्या तयार']
  : ['Work logged', 'Cost sorted', 'Tomorrow ready'];
---

<section
  data-scene="workflow"
  data-soil="wet-irrigated"
  data-cursor="mic"
  class="relative py-section overflow-hidden"
  style="background:var(--bg-surface);"
>
  <!-- Ambient background glow -->
  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 72% 50% at 50% 10%, rgba(217,119,6,0.07) 0%, transparent 46%), radial-gradient(ellipse 52% 36% at 82% 72%, rgba(20,83,45,0.06) 0%, transparent 50%);" aria-hidden="true"></div>

  <div class="relative z-10 max-w-site mx-auto px-5 md:px-8">

    <!-- Section header -->
    <div class="max-w-3xl mx-auto text-center mb-12">
      <span class="chapter-mark" data-chapter>
        {isMr ? 'Chapter 04 · बोला आणि नोंद' : 'Chapter 04 · Speak and We Sort'}
      </span>
      <h2 class="font-serif text-h2 mb-6" style="color:var(--text-primary);">
        {t.transcript.headline}
      </h2>
      <p class="text-body-lg max-w-prose mx-auto" style="color:var(--text-secondary);">
        {t.transcript.body}
      </p>
    </div>

    <!-- Unified canvas: timeline rail + demo, all in one block -->
    <div class="wf-canvas">
      <div class="wf-canvas__grid">

      <!-- ── LEFT: timeline rail ────────────────────────────────────── -->
      <ol class="wf-rail">
        {stageLabels.map((stage, index) => (
          <li class="wf-rail__item">
            <span class="wf-rail__dot" data-step={index}>0{index + 1}</span>
            <div class="wf-rail__content">
              <h3 class="wf-rail__title">{stage.title}</h3>
              <p class="wf-rail__body">{stage.body}</p>
            </div>
          </li>
        ))}
      </ol>

      <!-- ── RIGHT: voice → result visual ─────────────────────────── -->
      <div class="wf-visual-col">

        <!-- 1 · Voice input card -->
        <div class="wf-card wf-card--voice">
          <!-- Header row -->
          <div class="wf-card__header">
            <div class="wf-mic-wrap" aria-hidden="true">
              <div class="wf-mic-pulse wf-mic-pulse--ring wf-mic-pulse--ring-1"></div>
              <div class="wf-mic-pulse wf-mic-pulse--ring wf-mic-pulse--ring-2"></div>
              <div class="wf-mic-core">
                <!-- Mic icon — pure CSS, no SVG path -->
                <span class="wf-mic-icon" aria-hidden="true"></span>
              </div>
            </div>
            <div>
              <p class="wf-card__label">{isMr ? 'आवाज ऐकतो' : 'Listening…'}</p>
              <div class="wf-wave" aria-hidden="true">
                {Array.from({length: 14}).map((_, i) => (
                  <span class="wf-bar" style={`--i:${i};`}></span>
                ))}
              </div>
            </div>
          </div>

          <!-- Voice bubble -->
          <div class="wf-bubble">
            <p class="wf-bubble__text">{voiceText}</p>
          </div>

          <!-- Input tags (what was said) -->
          <div class="wf-tags wf-tags--input">
            {inputTags.map(tag => (
              <span class="wf-tag wf-tag--input">{tag}</span>
            ))}
          </div>
        </div>

        <!-- Connector arrow -->
        <div class="wf-connector" aria-hidden="true">
          <div class="wf-connector__line"></div>
          <div class="wf-connector__dot"></div>
          <div class="wf-connector__label">
            {isMr ? 'ShramSafal रचतो' : 'ShramSafal structures it'}
          </div>
          <div class="wf-connector__dot"></div>
          <div class="wf-connector__line"></div>
        </div>

        <!-- 2 · Structured result card with real app screenshot -->
        <div class="wf-card wf-card--result">

          <!-- Centered eyebrow: Live pill -->
          <div class="wf-result-eyebrow">
            <span class="wf-live-pill">
              <span class="wf-live-pill__dot" aria-hidden="true"></span>
              {isMr ? 'लाइव्ह' : 'Live'}
            </span>
          </div>

          <!-- Centered serif title -->
          <p class="wf-result-title">
            {isMr ? 'क्रॉप अ‍ॅक्टिव्हिटी — नोंद झाली' : 'Crop Activity — Logged'}
          </p>

          <!-- Centered app screenshot frame -->
          <div class="wf-screen-device">
            <div class="wf-screen-frame">
              <img
                src="/images/app-screens/screen-crop-activity.png"
                alt={isMr ? 'क्रॉप अ‍ॅक्टिव्हिटी स्क्रीन' : 'Crop Activity screen'}
                class="wf-screen-img"
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>

          <!-- Centered output tags row -->
          <div class="wf-output-tags">
            {outputTags.map(tag => (
              <span class="wf-output-tag">
                <span class="wf-output-tag__check" aria-hidden="true"></span>
                {tag}
              </span>
            ))}
          </div>
        </div>

      </div>
      </div>

      <!-- Caption (centered under the unified canvas) -->
      <p class="wf-caption">
        {isMr
          ? 'वर आवाज. मध्ये नोंद. खाली उद्याचा वापर.'
          : 'Voice comes in. Structure appears. Tomorrow becomes usable.'}
      </p>
    </div>

    <!-- Clarity bridge pull-quote (was Ch.05 · ClaritySection) -->
    <div class="wf-clarity-bridge" data-reveal data-reveal-delay="0.1">
      <p>
        {isMr
          ? '"एकच बोलणे — दोन प्रकारचे दृश्य. काय झाले, काय खर्च झाले, पुढे काय."'
          : '"One conversation — two views. What was done, what was spent, what comes next."'}
      </p>
    </div>
  </div>
</section>

<style>
  /* ── Unified canvas (γ wrapper) ──────────────────────────────────────── */
  .wf-canvas {
    background: rgba(255, 252, 244, 0.96);
    border: 1px solid rgba(146, 64, 14, 0.10);
    border-radius: 2rem;
    padding: clamp(1.5rem, 3vw, 2.5rem);
    box-shadow:
      0 32px 72px rgba(146, 64, 14, 0.06),
      0 4px 12px rgba(146, 64, 14, 0.04),
      inset 0 1px 0 rgba(255, 255, 255, 0.8);
    position: relative;
  }

  .wf-canvas__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .wf-canvas__grid {
      grid-template-columns: 0.85fr 1.15fr;
      column-gap: 2.5rem;
    }
  }

  /* ── Timeline rail (β) ──────────────────────────────────────────────── */
  .wf-rail {
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
  }

  /* Continuous vertical line through the dots */
  .wf-rail::before {
    content: '';
    position: absolute;
    left: 1.125rem;
    top: 1.125rem;
    bottom: 1.125rem;
    width: 2px;
    background: linear-gradient(180deg,
      rgba(217, 119, 6, 0.40) 0%,
      rgba(20, 83, 45, 0.45) 50%,
      rgba(217, 119, 6, 0.40) 100%);
    border-radius: 1px;
    z-index: 0;
  }

  .wf-rail__item {
    display: grid;
    grid-template-columns: 2.25rem 1fr;
    column-gap: 1.1rem;
    padding: 0.4rem 0;
    position: relative;
  }

  .wf-rail__item + .wf-rail__item {
    margin-top: 1.6rem;
  }

  .wf-rail__dot {
    position: relative;
    z-index: 1;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 900;
    color: #fff;
    background: #D97706;
    border: 3px solid rgba(255, 252, 244, 0.96);
    box-shadow: 0 4px 12px rgba(217, 119, 6, 0.28);
    flex-shrink: 0;
  }

  /* Step 02 (the AI step) gets the brand green */
  .wf-rail__dot[data-step="1"] {
    background: var(--brand);
    box-shadow: 0 4px 12px rgba(20, 83, 45, 0.28);
  }

  .wf-rail__content {
    padding-top: 0.1rem;
  }

  .wf-rail__title {
    font-family: var(--font-serif);
    font-size: clamp(1.2rem, 1.8vw, 1.5rem);
    line-height: 1.25;
    color: var(--text-primary);
    margin: 0 0 0.5rem;
    font-weight: 600;
  }

  .wf-rail__body {
    font-family: var(--font-sans);
    font-size: clamp(0.95rem, 1.1vw, 1.05rem);
    line-height: 1.65;
    color: var(--text-secondary);
    margin: 0;
  }

  /* ── Visual column ───────────────────────────────────────────────────── */
  .wf-visual-col {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0;
  }

  /* ── Shared card chrome — lighter on the canvas ─────────────────────── */
  .wf-card {
    border-radius: 1.4rem;
    padding: 1.4rem 1.5rem;
    border: 1px solid rgba(146, 64, 14, 0.10);
  }

  .wf-card--voice {
    background: rgba(255, 255, 255, 0.72);
    box-shadow: 0 6px 18px rgba(146, 64, 14, 0.04);
  }

  .wf-card--result {
    background: rgba(255, 255, 255, 0.86);
    border-color: rgba(20, 83, 45, 0.12);
    box-shadow: 0 8px 22px rgba(20, 83, 45, 0.05);
  }

  .wf-card__header {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-bottom: 1rem;
  }

  .wf-card__label {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--text-muted);
  }

  /* ── Mic pulse animation ────────────────────────────────────────────── */
  .wf-mic-wrap {
    position: relative;
    width: 2.6rem;
    height: 2.6rem;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .wf-mic-pulse--ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1.5px solid rgba(217,119,6,0.35);
    animation: mic-ring 2.2s ease-out infinite;
  }

  .wf-mic-pulse--ring-2 {
    animation-delay: 0.9s;
  }

  @keyframes mic-ring {
    0%   { transform: scale(1);   opacity: 0.80; }
    100% { transform: scale(2.2); opacity: 0; }
  }

  .wf-mic-core {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: linear-gradient(135deg, #D97706, #F59E0B);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 2;
    box-shadow: 0 4px 12px rgba(217,119,6,0.35);
  }

  /* CSS-only mic icon (body + stand) — no SVG path */
  .wf-mic-icon {
    display: block;
    width: 0.45rem;
    height: 0.65rem;
    background: #fff;
    border-radius: 999px 999px 999px 999px;
    position: relative;
  }

  .wf-mic-icon::before {
    content: '';
    position: absolute;
    bottom: -0.28rem;
    left: 50%;
    transform: translateX(-50%);
    width: 0.7rem;
    height: 0.35rem;
    border: 1.5px solid #fff;
    border-top: none;
    border-radius: 0 0 999px 999px;
  }

  .wf-mic-icon::after {
    content: '';
    position: absolute;
    bottom: -0.5rem;
    left: 50%;
    transform: translateX(-50%);
    width: 1.5px;
    height: 0.28rem;
    background: #fff;
  }

  /* ── Waveform bars (CSS only) ───────────────────────────────────────── */
  .wf-wave {
    display: flex;
    align-items: center;
    gap: 2.5px;
    height: 1.6rem;
    margin-top: 0.25rem;
  }

  .wf-bar {
    display: inline-block;
    width: 3px;
    border-radius: 3px;
    background: linear-gradient(to top, var(--gold), #F59E0B);
    animation: wf-pulse 1.3s ease-in-out infinite;
    animation-delay: calc(var(--i) * 0.07s);
  }

  /* Varied bar heights — creates realistic waveform without SVG */
  .wf-bar:nth-child(1)  { height: 6px; }
  .wf-bar:nth-child(2)  { height: 14px; }
  .wf-bar:nth-child(3)  { height: 20px; }
  .wf-bar:nth-child(4)  { height: 10px; }
  .wf-bar:nth-child(5)  { height: 22px; }
  .wf-bar:nth-child(6)  { height: 16px; }
  .wf-bar:nth-child(7)  { height: 8px; }
  .wf-bar:nth-child(8)  { height: 18px; }
  .wf-bar:nth-child(9)  { height: 24px; }
  .wf-bar:nth-child(10) { height: 12px; }
  .wf-bar:nth-child(11) { height: 20px; }
  .wf-bar:nth-child(12) { height: 8px; }
  .wf-bar:nth-child(13) { height: 14px; }
  .wf-bar:nth-child(14) { height: 6px; }

  @keyframes wf-pulse {
    0%, 100% { transform: scaleY(1);   opacity: 0.80; }
    50%       { transform: scaleY(0.4); opacity: 0.40; }
  }

  /* ── Voice bubble ───────────────────────────────────────────────────── */
  .wf-bubble {
    background: linear-gradient(135deg, #FFF8EE, #FFF4E0);
    border: 1px solid rgba(217,119,6,0.16);
    border-radius: 1rem 1rem 1rem 0.25rem;
    padding: 0.85rem 1.1rem;
    margin-bottom: 1rem;
  }

  .wf-bubble__text {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.65;
    color: rgba(90,60,20,0.88);
    font-style: italic;
  }

  /* ── Tags ───────────────────────────────────────────────────────────── */
  .wf-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .wf-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 800;
  }

  .wf-tag--input {
    background: #FFF5DF;
    color: rgba(102,76,39,0.86);
    border: 1px solid rgba(245,158,11,0.20);
  }

  .wf-tag--output {
    background: #F0FFF6;
    color: #166534;
    border: 1px solid rgba(20,83,45,0.16);
  }

  /* CSS checkmark — no SVG */
  .wf-check {
    display: inline-block;
    width: 0.65rem;
    height: 0.65rem;
    border-radius: 50%;
    background: rgba(20,83,45,0.15);
    position: relative;
    flex-shrink: 0;
  }

  .wf-check::after {
    content: '';
    position: absolute;
    top: 0.15rem;
    left: 0.18rem;
    width: 0.28rem;
    height: 0.18rem;
    border-left: 1.5px solid #14532D;
    border-bottom: 1.5px solid #14532D;
    transform: rotate(-45deg);
  }

  /* ── Connector ───────────────────────────────────────────────────────── */
  .wf-connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.45rem;
    padding: 0.6rem 0;
  }

  .wf-connector__line {
    width: 1px;
    height: 1.6rem;
    background: linear-gradient(to bottom, rgba(20,83,45,0.18), rgba(20,83,45,0.08));
  }

  .wf-connector__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--brand);
    opacity: 0.5;
  }

  .wf-connector__label {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.20em;
    color: var(--brand);
    opacity: 0.72;
  }

  /* ── Result card centered redesign ─────────────────────────────────── */
  .wf-card--result {
    text-align: center;
    padding: 1.5rem 1.25rem 1.4rem;
  }

  .wf-result-eyebrow {
    display: flex;
    justify-content: center;
    margin-bottom: 0.65rem;
  }

  .wf-live-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.32rem 0.78rem;
    border-radius: 999px;
    background: rgba(20,83,45,0.08);
    border: 1px solid rgba(20,83,45,0.20);
    font-family: var(--font-sans);
    font-size: 0.66rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--brand);
  }

  .wf-live-pill__dot {
    display: block;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: #22C55E;
    box-shadow: 0 0 0 3px rgba(34,197,94,0.18);
    animation: live-blink 1.4s ease-in-out infinite;
  }

  @keyframes live-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.4; }
  }

  .wf-result-title {
    font-family: var(--font-serif);
    font-size: clamp(1.05rem, 1.6vw, 1.3rem);
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.35;
    margin: 0 0 1.25rem;
  }

  /* ── App screenshot frame (centered, lightweight) ──────────────────── */
  .wf-screen-device {
    display: flex;
    justify-content: center;
    margin: 0.25rem 0 1.25rem;
  }

  .wf-screen-frame {
    width: 280px;
    max-width: 100%;
    border-radius: 1.4rem;
    overflow: hidden;
    background: #fff;
    border: 1px solid rgba(20, 83, 45, 0.10);
    box-shadow:
      0 24px 48px rgba(15, 18, 12, 0.16),
      0 4px 10px rgba(15, 18, 12, 0.08);
  }

  .wf-screen-img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: inherit;
  }

  /* ── Centered output tags row ─────────────────────────────────────── */
  .wf-output-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem 0.6rem;
    margin-top: 0.25rem;
  }

  .wf-output-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    padding: 0.42rem 0.85rem;
    border-radius: 999px;
    background: rgba(20,83,45,0.06);
    border: 1px solid rgba(20,83,45,0.18);
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--brand);
  }

  .wf-output-tag__check {
    position: relative;
    width: 0.95rem;
    height: 0.95rem;
    border-radius: 50%;
    background: rgba(34,197,94,0.18);
    flex-shrink: 0;
  }

  .wf-output-tag__check::after {
    content: '';
    position: absolute;
    top: 0.26rem;
    left: 0.27rem;
    width: 0.4rem;
    height: 0.22rem;
    border-left: 1.6px solid var(--brand);
    border-bottom: 1.6px solid var(--brand);
    transform: rotate(-45deg);
  }

  /* ── Caption ────────────────────────────────────────────────────────── */
  .wf-caption {
    text-align: center;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    line-height: 1.8;
    color: var(--text-muted);
    font-style: italic;
    padding: 0.75rem 1rem 0;
  }

  /* ── Clarity bridge pull-quote ─────────────────────────────────────────── */
  .wf-clarity-bridge {
    margin-top: 2.5rem;
    padding: 1.5rem 2rem;
    border-left: 3px solid var(--brand-fresh);
    background: rgba(22,163,74,0.04);
    border-radius: 0 1rem 1rem 0;
    max-width: 36rem;
    margin-inline: auto;
  }

  .wf-clarity-bridge p {
    font-family: var(--font-serif);
    font-size: clamp(1.05rem, 1.8vw, 1.3rem);
    font-style: italic;
    color: var(--text-secondary);
    line-height: 1.65;
    text-align: center;
  }

  /* ── Reduced motion ─────────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .wf-bar              { animation: none; }
    .wf-mic-pulse--ring  { animation: none; }
    .wf-live-pill__dot   { animation: none; }
  }
</style>
