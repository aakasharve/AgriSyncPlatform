---
/**
 * HeroSection — Chapter 01 · The Farm
 * Product landing page layout: copy LEFT, floating phone RIGHT.
 * Phone is a foreground showcase element (not a background fill).
 * Ambient green glow + subtle 3D tilt + floating badges = premium feel.
 */
import { getLangFromUrl, getTranslations } from '../../i18n/translations';

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
const isMr = lang === 'mr';
---

<section
  data-scene="hero"
  data-soil="kachi-mati"
  class="hero"
>
  <!-- Full-width seam: cinematic scroll dark close → warm Kachi Mati -->
  <div class="hero__seam" aria-hidden="true"></div>

  <!-- Decorative texture grain -->
  <div class="hero__grain" aria-hidden="true"></div>

  <div class="hero__inner max-w-site mx-auto px-5 md:px-8">

    <!-- ── LEFT: copy ──────────────────────────────────────────────── -->
    <div class="hero__copy">
      <span class="hero__chapter">
        {isMr ? 'Chapter 01 · शेत' : 'Chapter 01 · The Farm'}
      </span>

      <h1
        class="font-serif hero__headline"
        set:html={t.hero.headline.replace(/\n/g, '<br />')}
      />

      <p class="hero__sub">{t.hero.subheadline}</p>

      <div class="hero__ctas">
        <a href="#cta" class="hero__cta-primary magnetic-btn">
          {t.hero.cta_primary}
          <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
        <a href="#problem-hit" class="hero__cta-ghost magnetic-btn">
          {t.hero.cta_secondary}
        </a>
      </div>

      <p class="hero__microline" aria-hidden="true">{t.hero.microline}</p>

      <!-- Feature pills -->
      <div class="hero__pills">
        <span class="hero__pill">
          <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true" style="color:var(--brand-fresh)">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z" />
          </svg>
          {isMr ? 'आवाजाने नोंद' : 'Voice logging'}
        </span>
        <span class="hero__pill">
          <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true" style="color:var(--gold)">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
          </svg>
          {isMr ? '९० दिवस विश्वास' : '90-day trust'}
        </span>
        <span class="hero__pill">
          <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true" style="color:#60A5FA">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.288 15.038a5.25 5.25 0 017.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 011.06 0z" />
          </svg>
          {isMr ? 'ऑफलाइन चालतो' : 'Works offline'}
        </span>
      </div>

      <!-- Stat row -->
      <div class="hero__stats">
        <div class="hero__stat">
          <span class="hero__stat-num">10s</span>
          <span class="hero__stat-label">{isMr ? 'प्रति नोंद' : 'per log'}</span>
        </div>
        <div class="hero__stat-sep" aria-hidden="true"></div>
        <div class="hero__stat">
          <span class="hero__stat-num">90d</span>
          <span class="hero__stat-label">{isMr ? 'विश्वासार्ह नोंद' : 'verifiable record'}</span>
        </div>
        <div class="hero__stat-sep" aria-hidden="true"></div>
        <div class="hero__stat">
          <span class="hero__stat-num">∞</span>
          <span class="hero__stat-label">Offline</span>
        </div>
      </div>
    </div>

    <!-- ── RIGHT: phone showcase ──────────────────────────────────── -->
    <div class="hero__stage" aria-hidden="true">

      <!-- Ambient glow pools behind phone -->
      <div class="hero__glow hero__glow--green"></div>
      <div class="hero__glow hero__glow--gold"></div>

      <!-- Decorative rings -->
      <div class="hero__ring hero__ring--outer"></div>
      <div class="hero__ring hero__ring--inner"></div>

      <!-- Phone — floating, 3D tilted, drop-shadowed -->
      <div class="hero__phone-wrap">
        <img
          src="/images/app-screens/screen-daily-log.png"
          alt={isMr ? 'श्रमसफल अ‍ॅप' : 'ShramSafal app'}
          class="hero__phone"
          loading="eager"
          decoding="async"
        />
      </div>

      <!-- Floating feature badges around phone -->
      <div class="hero__badge hero__badge--voice">
        <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z" />
        </svg>
        {isMr ? 'आवाजाने नोंद झाली' : 'Logged by voice'}
      </div>

      <div class="hero__badge hero__badge--cost">
        <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33" />
        </svg>
        {isMr ? 'खर्च दिसतो' : 'Running cost live'}
      </div>

      <div class="hero__badge hero__badge--offline">
        <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.288 15.038a5.25 5.25 0 017.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 011.06 0z" />
        </svg>
        Offline ready
      </div>
    </div>

  </div>
</section>

<style>
  /* ── Section shell ──────────────────────────────────────────────────── */
  .hero {
    position: relative;
    overflow: clip;
    background: var(--bg-base);
    padding-top: clamp(5rem, 10vw, 8rem);
    padding-bottom: clamp(4rem, 8vw, 7rem);
  }

  /* ── Seam: dark cinematic scroll close → warm clay ─────────────────── */
  .hero__seam {
    position: absolute;
    inset-x: 0;
    top: 0;
    height: 9rem;
    z-index: 2;
    pointer-events: none;
    background: linear-gradient(
      to bottom,
      #0F1A10 0%,
      #111E12 14%,
      #1A2B17 34%,
      rgba(26,43,23,0.55) 58%,
      transparent 100%
    );
  }

  /* ── Grain overlay (subtle depth texture) ───────────────────────────── */
  .hero__grain {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    opacity: 0.022;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.80' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  /* ── Inner grid ─────────────────────────────────────────────────────── */
  .hero__inner {
    position: relative;
    z-index: 10;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero__inner {
      grid-template-columns: 1fr 1fr;
      gap: clamp(2rem, 5vw, 6rem);
      min-height: 86vh;
    }
  }

  /* ── Copy column ────────────────────────────────────────────────────── */
  .hero__copy {
    display: flex;
    flex-direction: column;
    padding-top: 3rem; /* clear the seam */
  }

  @media (min-width: 1024px) {
    .hero__copy { padding-top: 0; }
  }

  /* ── Chapter mark ───────────────────────────────────────────────────── */
  .hero__chapter {
    display: inline-block;
    margin-bottom: 1.6rem;
    font-size: 0.64rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.28em;
    color: var(--gold);
    border-left: 2px solid var(--gold);
    padding-left: 0.65rem;
  }

  /* ── Headline ───────────────────────────────────────────────────────── */
  .hero__headline {
    font-family: var(--font-serif);
    font-size: clamp(2.4rem, 5.2vw, 4.6rem);
    font-weight: 700;
    line-height: max(1.1, var(--heading-line-height, 1.15));
    letter-spacing: var(--heading-letter-spacing, -0.02em);
    color: var(--text-primary);
    margin-bottom: 1.4rem;
    text-wrap: balance;
  }

  /* ── Sub ────────────────────────────────────────────────────────────── */
  .hero__sub {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.5vw, 1.12rem);
    line-height: 1.76;
    color: var(--text-secondary);
    max-width: 34rem;
    margin-bottom: 2rem;
  }

  /* ── CTAs ───────────────────────────────────────────────────────────── */
  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .hero__cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.95rem 2rem;
    border-radius: 0.9rem;
    font-family: var(--font-sans);
    font-weight: 800;
    font-size: 1rem;
    color: #fff;
    background: linear-gradient(135deg, var(--brand), var(--brand-fresh));
    box-shadow: 0 12px 32px rgba(20,83,45,0.28);
    text-decoration: none;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
    cursor: pointer;
  }
  .hero__cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 44px rgba(20,83,45,0.38);
  }

  .hero__cta-ghost {
    display: inline-flex;
    align-items: center;
    padding: 0.95rem 2rem;
    border-radius: 0.9rem;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1rem;
    color: var(--text-primary);
    border: 1px solid var(--border-mid);
    background: rgba(255,255,255,0.72);
    text-decoration: none;
    transition: transform 0.18s ease, background 0.18s ease;
    cursor: pointer;
  }
  .hero__cta-ghost:hover {
    transform: translateY(-2px);
    background: rgba(255,255,255,0.92);
  }

  /* ── Microline ──────────────────────────────────────────────────────── */
  .hero__microline {
    font-family: var(--font-sans);
    font-size: 0.88rem;
    font-style: italic;
    color: var(--text-muted);
    margin-bottom: 1.6rem;
  }

  /* ── Pills ──────────────────────────────────────────────────────────── */
  .hero__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-bottom: 2rem;
  }

  .hero__pill {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.5rem 0.9rem;
    border-radius: 999px;
    border: 1px solid var(--border-light);
    background: rgba(255,255,255,0.78);
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-size: 0.84rem;
    font-weight: 700;
  }

  /* ── Stats row ──────────────────────────────────────────────────────── */
  .hero__stats {
    display: flex;
    align-items: center;
    gap: 1.4rem;
    padding: 1.2rem 0;
    border-top: 1px solid var(--border-light);
    max-width: 32rem;
  }

  .hero__stat {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .hero__stat-num {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 400;
    line-height: 1;
    color: var(--brand);
  }

  .hero__stat-label {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--text-muted);
  }

  .hero__stat-sep {
    width: 1px;
    height: 2.4rem;
    background: var(--border-light);
    flex-shrink: 0;
  }

  /* ══════════════════════════════════════════════════════════════════════
     PHONE SHOWCASE STAGE
  ══════════════════════════════════════════════════════════════════════ */

  .hero__stage {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    /* Enough height to show the floating badges without clipping */
    padding: 3.5rem 3rem;
  }

  @media (min-width: 1024px) {
    .hero__stage {
      padding: 4rem 2rem;
      justify-content: flex-end;
    }
  }

  /* ── Ambient glow pools ─────────────────────────────────────────────── */
  .hero__glow {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(72px);
  }

  .hero__glow--green {
    width: 38rem;
    height: 38rem;
    top: 50%;
    left: 50%;
    transform: translate(-46%, -52%);
    background: radial-gradient(circle, rgba(20,83,45,0.14) 0%, transparent 68%);
  }

  .hero__glow--gold {
    width: 24rem;
    height: 24rem;
    bottom: 5%;
    right: 8%;
    background: radial-gradient(circle, rgba(217,119,6,0.10) 0%, transparent 68%);
  }

  /* ── Decorative rings ───────────────────────────────────────────────── */
  .hero__ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(20,83,45,0.10);
    pointer-events: none;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    animation: ring-pulse 6s ease-in-out infinite;
  }

  .hero__ring--outer {
    width: 34rem;
    height: 34rem;
    animation-delay: 0s;
  }

  .hero__ring--inner {
    width: 24rem;
    height: 24rem;
    border-color: rgba(20,83,45,0.07);
    animation-delay: 1.2s;
  }

  @keyframes ring-pulse {
    0%, 100% { opacity: 0.55; transform: translate(-50%, -50%) scale(1); }
    50%       { opacity: 0.90; transform: translate(-50%, -50%) scale(1.03); }
  }

  /* ── Phone wrapper — float animation ───────────────────────────────── */
  .hero__phone-wrap {
    position: relative;
    z-index: 4;
    animation: hero-float 6s ease-in-out infinite;
    /* 3D perspective tilt — gives product-showcase depth */
    transform: perspective(1200px) rotateY(-6deg) rotateX(2deg);
  }

  @keyframes hero-float {
    0%, 100% { translate: 0 0px; }
    50%       { translate: 0 -14px; }
  }

  /* ── Phone image ────────────────────────────────────────────────────── */
  .hero__phone {
    display: block;
    /* Tall enough to be impressive, never overflows */
    height: clamp(420px, 56vh, 680px);
    width: auto;
    max-width: 100%;
    object-fit: contain;
    border-radius: 2rem;
    /* Layered shadows for depth: deep base + close ambient + ring highlight */
    filter:
      drop-shadow(0 48px 96px rgba(10,20,12,0.36))
      drop-shadow(0 16px 40px rgba(10,20,12,0.22))
      drop-shadow(0 4px 12px rgba(10,20,12,0.14));
    user-select: none;
    -webkit-user-drag: none;
  }

  /* ── Floating feature badges ────────────────────────────────────────── */
  .hero__badge {
    position: absolute;
    z-index: 8;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.5rem 1rem;
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 0.74rem;
    font-weight: 800;
    background: rgba(255,255,255,0.94);
    border: 1px solid rgba(146,64,14,0.12);
    box-shadow: 0 8px 28px rgba(0,0,0,0.12), 0 2px 8px rgba(0,0,0,0.06);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    color: var(--text-primary);
    white-space: nowrap;
    pointer-events: none;
  }

  /* Voice badge — top left of phone */
  .hero__badge--voice {
    top: 18%;
    left: -1rem;
    color: var(--brand);
    animation: badge-drift-a 5.5s ease-in-out infinite;
  }

  /* Cost badge — middle right */
  .hero__badge--cost {
    top: 52%;
    right: -0.5rem;
    color: var(--gold);
    animation: badge-drift-b 6.2s ease-in-out infinite 0.8s;
  }

  /* Offline badge — bottom left */
  .hero__badge--offline {
    bottom: 20%;
    left: -0.5rem;
    color: #3B82F6;
    animation: badge-drift-a 7s ease-in-out infinite 1.6s;
  }

  @keyframes badge-drift-a {
    0%, 100% { transform: translate(0, 0); }
    50%       { transform: translate(-5px, -8px); }
  }

  @keyframes badge-drift-b {
    0%, 100% { transform: translate(0, 0); }
    50%       { transform: translate(5px, -8px); }
  }

  /* ── Mobile: badges hidden to avoid overflow issues ─────────────────── */
  @media (max-width: 639px) {
    .hero__badge { display: none; }
    .hero__ring  { display: none; }
    .hero__phone {
      height: clamp(320px, 65vw, 420px);
      transform: none;
    }
    .hero__phone-wrap {
      transform: none;
    }
  }

  /* ── Reduced motion ─────────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .hero__phone-wrap { animation: none; transform: none; }
    .hero__badge      { animation: none; }
    .hero__ring       { animation: none; }
  }
</style>
