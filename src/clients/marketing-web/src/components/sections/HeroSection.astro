---
import { getLangFromUrl, getTranslations } from '../../i18n/translations';
import SahyadriHills from '../svg/SahyadriHills.astro';
import CropSilhouette from '../svg/CropSilhouette.astro';
import GoldenHorizon from '../svg/GoldenHorizon.astro';

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
const chapterLabel = lang === 'mr' ? 'Chapter 01 · शेत' : 'Chapter 01 · The Farm';
const heroAnnotation = lang === 'mr' ? 'वा! इतकं जलद?' : 'So fast?';
---

<section
  data-scene="hero"
  data-soil="cotton-black"
  data-cursor="kite"
  class="relative min-h-screen overflow-hidden"
  style="background:var(--bg-base);"
>
  <!-- Grain texture -->
  <div class="absolute inset-0 pointer-events-none" style="background-image:url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E&quot;); opacity:0.04; z-index:1;" aria-hidden="true"></div>

  <!-- Golden rim glow rising from base -->
  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 130% 55% at 50% 110%, rgba(245,158,11,0.26) 0%, transparent 58%);z-index:2;" aria-hidden="true"></div>

  <!-- Sahyadri hills — 3 parallax layers -->
  <SahyadriHills depth={1} />
  <SahyadriHills depth={2} />
  <SahyadriHills depth={3} />

  <!-- Crop silhouettes at base -->
  <CropSilhouette count={24} variant="mixed" goldGlow={true} height={110} />

  <!-- ═══════════════════════════════════════════
       CONTENT ZONE — Film Credits, bottom-left
       ═══════════════════════════════════════════ -->
  <div class="relative z-10 min-h-screen flex items-end">
    <div class="w-full max-w-site mx-auto px-6 md:px-10 pb-36 md:pb-40 grid grid-cols-1 lg:grid-cols-2 gap-8 items-end">

      <!-- LEFT: Story block -->
      <div class="max-w-lg">
        <!-- Chapter mark -->
        <span class="chapter-mark" data-chapter>{chapterLabel}</span>

        <!-- Headline -->
        <h1
          class="font-serif text-[clamp(2.2rem,6vw,4rem)] text-white font-bold leading-[1.12] tracking-tight mb-5"
          style="text-shadow:0 2px 40px rgba(0,0,0,0.5);"
          data-split-headline
        >
          {t.hero.headline}
        </h1>

        <p class="text-[clamp(0.95rem,1.5vw,1.1rem)] mb-8" style="color:var(--white-55);line-height:1.7;max-width:44ch;">
          {t.hero.subheadline}
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-3 mb-6" data-reveal>
          <a
            href="#guided-questions"
            class="inline-flex items-center justify-center gap-2 font-extrabold text-white px-8 py-3.5 rounded-lg transition-all hover:-translate-y-0.5"
            style="background:var(--brand);box-shadow:0 8px 32px rgba(16,185,129,0.35);"
          >
            {t.hero.cta_primary}
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          </a>
          <a
            href="#problem-hit"
            class="inline-flex items-center justify-center font-bold px-8 py-3.5 rounded-lg transition-all"
            style="border:1px solid var(--white-10);color:var(--white-70);backdrop-filter:blur(8px);"
          >
            {t.hero.cta_secondary}
          </a>
        </div>

        <p class="text-sm italic" style="color:var(--white-40);">{t.hero.microline}</p>

        <!-- Stat pills -->
        <div class="flex flex-wrap gap-2 mt-6" data-reveal>
          <div class="stat-pill">
            <svg class="w-3.5 h-3.5" style="color:var(--brand-fresh);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z"/></svg>
            {lang === 'mr' ? 'आवाजाने लॉग' : 'Voice logging'}
          </div>
          <div class="stat-pill">
            <svg class="w-3.5 h-3.5" style="color:var(--gold);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
            {lang === 'mr' ? '९० दिवस विश्वास' : '90-day trust'}
          </div>
          <div class="stat-pill">
            <svg class="w-3.5 h-3.5" style="color:var(--farm-sky);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.288 15.038a5.25 5.25 0 017.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 011.06 0z"/></svg>
            {lang === 'mr' ? 'ऑफलाइन चालतो' : 'Works offline'}
          </div>
        </div>
      </div>

      <!-- RIGHT: 3D phone mockup + white mandi card -->
      <div class="hidden lg:flex flex-col items-center gap-6 relative">

        <!-- White contrast card — mandi price -->
        <div class="card-white absolute -top-8 -right-4 px-4 py-3 shadow-2xl z-20" style="min-width:140px;" data-reveal>
          <div class="text-xs font-bold uppercase tracking-wider mb-1" style="color:rgba(28,25,23,0.5);">{lang === 'mr' ? 'आजचा भाव' : "Today's price"}</div>
          <div class="font-extrabold text-xl" style="color:#059669;">₹45/kg</div>
          <div class="text-sm font-semibold" style="color:rgba(28,25,23,0.65);">{lang === 'mr' ? 'द्राक्षे ↑₹3' : 'Grapes ↑₹3'}</div>
          <div class="absolute top-2 right-2 text-[9px] font-bold uppercase tracking-wider" style="color:rgba(5,150,105,0.6);">LIVE</div>
        </div>

        <!-- 3D Phone frame -->
        <div
          class="relative"
          data-phone-3d
          style="transform:perspective(800px) rotateY(-14deg) rotateX(4deg);transform-origin:center center;"
        >
          <!-- Phone glow -->
          <div class="absolute -inset-6 pointer-events-none" style="background:radial-gradient(ellipse at center, rgba(16,185,129,0.15) 0%, transparent 65%);filter:blur(16px);" aria-hidden="true"></div>

          <!-- Phone body -->
          <div class="relative rounded-[2.2rem] overflow-hidden shadow-[0_32px_80px_rgba(0,0,0,0.6),0_0_0_1px_rgba(16,185,129,0.15)]"
               style="width:200px;background:var(--bg-elevated);border:2px solid rgba(16,185,129,0.18);">

            <!-- Notch -->
            <div class="flex justify-center pt-3 pb-1">
              <div class="w-16 h-1.5 rounded-full" style="background:rgba(255,255,255,0.1);"></div>
            </div>

            <!-- Screen header -->
            <div class="px-4 pt-2 pb-3" style="background:linear-gradient(135deg,var(--brand),var(--brand-hover));">
              <div class="text-white font-bold text-sm">ShramSafal</div>
              <div class="text-xs mt-0.5" style="color:rgba(255,255,255,0.7);">{lang === 'mr' ? 'आजचे काम' : "Today's work"}</div>
            </div>

            <!-- Log lines -->
            <div class="px-3 py-3 space-y-2">
              {[
                { w: '80%', c: 'rgba(16,185,129,0.5)'  },
                { w: '65%', c: 'rgba(245,158,11,0.4)'  },
                { w: '90%', c: 'rgba(16,185,129,0.35)' },
                { w: '55%', c: 'rgba(255,255,255,0.15)'},
                { w: '75%', c: 'rgba(245,158,11,0.3)'  },
                { w: '85%', c: 'rgba(16,185,129,0.4)'  },
              ].map(line => (
                <div class="h-1.5 rounded-full" style={`width:${line.w};background:${line.c};`}></div>
              ))}
            </div>

            <!-- Bottom nav bar -->
            <div class="flex justify-around px-4 py-3" style="border-top:1px solid rgba(255,255,255,0.06);">
              {[0,1,2,3].map(() => (
                <div class="w-5 h-5 rounded-md" style="background:rgba(255,255,255,0.06);"></div>
              ))}
            </div>
          </div>

          <!-- Stat chips beside phone -->
          <div class="absolute -right-28 top-1/2 -translate-y-1/2 flex flex-col gap-3">
            <div class="stat-chip-dark"><span style="color:var(--brand-fresh);font-weight:800;">10s</span> {lang === 'mr' ? 'प्रति नोंद' : 'per log'}</div>
            <div class="stat-chip-dark"><span style="color:var(--gold-warm);font-weight:800;">90d</span> {lang === 'mr' ? 'विश्वास' : 'trust'}</div>
            <div class="stat-chip-dark" style="color:var(--white-55);">Offline ✓</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-28 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 z-10" aria-hidden="true">
    <div class="w-5 h-8 rounded-full flex justify-center pt-1.5" style="border:1px solid rgba(255,255,255,0.2);">
      <div class="w-1 h-2 rounded-full animate-bounce" style="background:rgba(255,255,255,0.4);"></div>
    </div>
    <span class="text-[10px] font-bold tracking-widest uppercase" style="color:rgba(255,255,255,0.25);">{lang === 'mr' ? 'खाली' : 'Scroll'}</span>
  </div>

  <!-- Mandi ticker -->
  <div id="mandi-ticker" aria-label={lang === 'mr' ? 'बाजारभाव' : 'Market rates'}>
    <div class="mandi-ticker-inner" aria-hidden="true">
      <span class="mandi-item">🍇 {lang === 'mr' ? 'द्राक्षे' : 'Grapes'} ₹45/kg <span class="up">↑₹3</span></span>
      <span class="mandi-item">🧅 {lang === 'mr' ? 'कांदा' : 'Onion'} ₹22/kg <span class="down">↓₹5</span></span>
      <span class="mandi-item">{lang === 'mr' ? 'सोयाबीन' : 'Soybean'} ₹4,850/qtl <span class="up">↑₹120</span></span>
      <span class="mandi-item">{lang === 'mr' ? 'गहू' : 'Wheat'} ₹2,275/qtl</span>
      <span class="mandi-item">{lang === 'mr' ? 'ऊस' : 'Sugarcane'} ₹3,100/ton <span class="up">↑₹50</span></span>
      <span class="mandi-item">🍊 {lang === 'mr' ? 'संत्रा' : 'Orange'} ₹35/kg <span class="down">↓₹2</span></span>
      <span class="mandi-item">{lang === 'mr' ? 'डाळिंब' : 'Pomegranate'} ₹80/kg <span class="up">↑₹8</span></span>
      <span class="mandi-item">{lang === 'mr' ? 'कापूस' : 'Cotton'} ₹6,200/qtl <span class="up">↑₹100</span></span>
      <!-- Duplicate for seamless loop -->
      <span class="mandi-item">🍇 {lang === 'mr' ? 'द्राक्षे' : 'Grapes'} ₹45/kg <span class="up">↑₹3</span></span>
      <span class="mandi-item">🧅 {lang === 'mr' ? 'कांदा' : 'Onion'} ₹22/kg <span class="down">↓₹5</span></span>
      <span class="mandi-item">{lang === 'mr' ? 'सोयाबीन' : 'Soybean'} ₹4,850/qtl <span class="up">↑₹120</span></span>
      <span class="mandi-item">{lang === 'mr' ? 'गहू' : 'Wheat'} ₹2,275/qtl</span>
    </div>
  </div>

  <!-- Bottom divider -->
  <GoldenHorizon dots={true} />
</section>

<style>
  .stat-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 5px 12px;
    border-radius: 999px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.10);
    color: rgba(255,255,255,0.70);
    backdrop-filter: blur(8px);
  }

  .stat-chip-dark {
    font-size: 0.7rem;
    padding: 5px 10px;
    border-radius: 8px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.07);
    color: rgba(255,255,255,0.55);
    white-space: nowrap;
  }

  /* Grass strip (keep for wind system compatibility) */
  #grass-strip {
    position: absolute;
    bottom: 112px;
    left: 0; right: 0;
    height: 40px;
    pointer-events: none;
    z-index: 4;
    display: flex;
    align-items: flex-end;
  }

  .grass-blade {
    position: absolute;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to top, rgba(16,185,129,0.4), transparent);
    border-radius: 2px 2px 0 0;
    transform-origin: bottom center;
    animation: sway var(--sway-dur, 2.5s) var(--sway-delay, 0s) ease-in-out infinite alternate;
  }

  @keyframes sway {
    0%   { transform: rotate(var(--lean, -2deg)); }
    100% { transform: rotate(calc(var(--lean, -2deg) + 6deg)); }
  }

  @media (prefers-reduced-motion: reduce) {
    .grass-blade { animation: none; }
  }
</style>
