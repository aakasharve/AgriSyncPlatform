---
import { getLangFromUrl, getTranslations } from '../../i18n/translations';
import BeforeAfterReveal from '../islands/BeforeAfterReveal';

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);

const beforeBody =
  lang === 'mr'
    ? 'दिवसभर काम होतं, पण शेवटी नेमकं काय झालं हे पुन्हा जोडावं लागतं. खर्च, मजूर, प्लॉट, उद्याचं काम सगळं वेगळं राहत नाही.'
    : 'The work happens, but the day still has to be reconstructed at night. Costs, labour, plots, and pending tasks keep slipping into one blurred story.';

const afterBody =
  lang === 'mr'
    ? 'त्याच शेतात, पण आता दिवस एकाच नजरेत दिसतो. काम, खर्च, पुढचं पाऊल आणि जबाबदारी वेगळी आणि स्पष्ट दिसते.'
    : 'Same farm, but now the day reads clearly. Work done, money spent, next action, and responsibility sit in one clean operating view.';
---

<BeforeAfterReveal
  eyebrow={lang === 'mr' ? 'Chapter 03 · बदल' : 'Chapter 03 · The Shift'}
  title={t.before_after.headline}
  description={lang === 'mr' ? 'गोंधळातून नियंत्रणाकडे. त्याच शेतात, वेगळी पकड.' : 'From mental load to operating grip. Same farm, very different control.'}
  beforeTitle={t.before_after.before_title}
  beforeBody={beforeBody}
  beforePoints={t.before_after.before_items}
  afterTitle={t.before_after.after_title}
  afterBody={afterBody}
  afterPoints={t.before_after.after_items}
/>
