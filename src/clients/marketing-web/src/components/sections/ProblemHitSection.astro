---
import { getLangFromUrl, getTranslations } from '../../i18n/translations';

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
---

<section
  id="problem-hit"
  data-scene="problem-hit"
  data-soil="cracked-dry"
  data-cursor="wilt"
  class="relative py-section overflow-hidden"
  style="background:var(--bg-base);"
>
  <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 62% 44% at 50% 14%, rgba(146,64,14,0.07) 0%, transparent 44%), radial-gradient(ellipse 44% 28% at 82% 84%, rgba(20,83,45,0.07) 0%, transparent 44%);" aria-hidden="true"></div>

  <div class="relative z-10 max-w-site mx-auto px-5 md:px-8">
    <div class="text-center max-w-3xl mx-auto mb-10 md:mb-14">
      <span class="chapter-mark" data-chapter>
        {lang === 'mr' ? 'Chapter 02 · अडचण कुठे आहे' : 'Chapter 02 · Where the Day Breaks'}
      </span>
      <h2 class="font-serif text-h2 mb-5" style="color:rgb(29,51,38);" set:html={t.problem_hit.headline.replace(/\n/g, '<br />')} />
      <p class="text-body-lg max-w-prose mx-auto" style="color:rgba(29,51,38,0.74);">
        {t.problem_hit.body}
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-[1.15fr_0.85fr] gap-8 lg:gap-12 items-center max-w-6xl mx-auto">
      <div class="grid gap-4" data-reveal-3d-group>
        {t.problem_hit.pain_lines.map((line: string, i: number) => (
          <div
            class="card-white rounded-2xl px-5 py-5 shadow-[0_12px_28px_rgba(146,64,14,0.07)]"
            data-reveal-3d-item
          >
            <div class="flex items-start gap-4">
              <div class="problem-pin" style={`background:${i % 2 === 0 ? '#D97706' : '#14532D'}`}></div>
              <div class="min-w-0">
                <div class="text-[0.68rem] font-extrabold uppercase tracking-[0.28em] mb-2" style="color:rgba(146,64,14,0.55);">
                  {lang === 'mr' ? `दिवसातील भंग 0${i + 1}` : `Breakpoint 0${i + 1}`}
                </div>
                <p class="text-lg md:text-[1.35rem] leading-8 font-semibold" style="color:var(--text-primary);">{line}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="rounded-[2rem] border border-[rgba(19,50,36,0.08)] bg-[rgba(17,49,34,0.92)] px-6 py-8 shadow-[0_24px_60px_rgba(0,0,0,0.16)]" data-zoom-section>
        <div class="relative w-56 h-56 mx-auto mb-6 flex justify-center items-center rounded-2xl overflow-hidden shadow-inner bg-[rgba(255,255,255,0.03)] border border-white/10">
          <img 
            src="/images/characters/problem-burdened-farmer.png" 
            alt={lang === 'mr' ? 'थकलेला शेतकरी' : 'Burdened farmer'} 
            class="w-full h-full object-cover opacity-90 mix-blend-luminosity hover:mix-blend-normal transition-all duration-500"
          />
        </div>

        <div class="mt-8 grid grid-cols-2 gap-3">
          {[
            lang === 'mr' ? 'खर्च?' : 'Cost?',
            lang === 'mr' ? 'मजूर?' : 'Labour?',
            lang === 'mr' ? 'बाकी?' : 'Pending?',
            lang === 'mr' ? 'कुठला प्लॉट?' : 'Which plot?',
          ].map((label) => (
            <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-4 text-center">
              <div class="text-sm font-bold tracking-wide" style="color:rgba(255,255,255,0.82);">{label}</div>
            </div>
          ))}
        </div>

        <p class="mt-6 text-center text-base leading-7" style="color:rgba(255,255,255,0.68);">
          {lang === 'mr'
            ? 'दिवसातलं काम अनेक तुकड्यांत विखुरतं. नोंद नसली की सगळं पुन्हा डोक्यात जोडावं लागतं.'
            : 'The day breaks into fragments. Without a record, everything has to be rebuilt from memory at night.'}
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .problem-pin {
    width: 0.5rem;
    min-width: 0.5rem;
    align-self: stretch;
    border-radius: 999px;
    box-shadow: 0 0 0 6px rgba(255,255,255,0.8);
  }

</style>
