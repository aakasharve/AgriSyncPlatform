---
import { getLangFromUrl, getTranslations } from '../../i18n/translations';

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);

const questionAnchors = ['qa-1', 'qa-2', 'qa-3', 'qa-4', 'qa-5'];

const questionMeta = [
  {
    icon: '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" /></svg>',
    accent: 'from-red-500/10 to-orange-500/8',
    border: 'hover:border-red-400/40',
    iconBg: 'bg-red-500/15 text-red-400',
    numColor: 'text-red-400',
  },
  {
    icon: '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>',
    accent: 'from-amber-500/10 to-yellow-500/8',
    border: 'hover:border-amber-400/40',
    iconBg: 'bg-amber-500/15 text-amber-400',
    numColor: 'text-amber-400',
  },
  {
    icon: '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" /></svg>',
    accent: 'from-blue-500/10 to-sky-500/8',
    border: 'hover:border-blue-400/40',
    iconBg: 'bg-blue-500/15 text-blue-400',
    numColor: 'text-blue-400',
  },
  {
    icon: '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>',
    accent: 'from-purple-500/10 to-violet-500/8',
    border: 'hover:border-purple-400/40',
    iconBg: 'bg-purple-500/15 text-purple-400',
    numColor: 'text-purple-400',
  },
  {
    icon: '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" /></svg>',
    accent: 'from-emerald-500/10 to-green-500/8',
    border: 'hover:border-emerald-400/40',
    iconBg: 'bg-emerald-500/15 text-emerald-400',
    numColor: 'text-emerald-400',
  },
];
---

<section
  id="guided-questions"
  data-scene="guided"
  data-soil="tilled"
  data-cursor="seedling"
  class="relative py-14 md:py-20 overflow-hidden"
>
  <div class="absolute inset-0" style="background:var(--bg-surface);"></div>

  <div class="relative z-10 max-w-site mx-auto px-5 md:px-8">
    <div class="text-center max-w-2xl mx-auto mb-8 md:mb-10">
      <span class="chapter-mark" data-chapter>
        {lang === 'mr' ? 'Chapter 03 · निदान' : 'Chapter 03 · Diagnosis'}
      </span>
      <h2
        class="scene-stagger font-serif text-h2 mb-5"
        style="color:var(--text-primary);"
        set:html={t.guided.headline.replace(/\n/g, '<br />')}
      />
      <p class="scene-stagger text-body-lg max-w-prose mx-auto" style="color:rgba(29,51,38,0.72);">
        {t.guided.body}
      </p>
    </div>

    <div class="field-questions-shell scene-stagger max-w-6xl mx-auto">
      <div class="field-questions-shell__rows" aria-hidden="true"></div>
      <div class="field-footprints" aria-hidden="true">
        {Array.from({ length: 6 }, (_, index) => (
          <span class="field-footprint" style={`--foot-index:${index}; --foot-left:${10 + index * 14}%; --foot-top:${12 + index * 13}%; --foot-rotate:${index % 2 === 0 ? '-16deg' : '12deg'};`}></span>
        ))}
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 max-w-5xl mx-auto relative z-10">
        {t.guided.questions.map((q: string, i: number) => {
          const meta = questionMeta[i];
          return (
            <a
              href={`#${questionAnchors[i]}`}
              class:list={[
                'question-card question-plot-card group relative flex flex-col items-center text-center p-5 md:p-6 rounded-2xl',
                'card-white',
                'transition-all duration-300',
                'hover:-translate-y-1.5 hover:shadow-xl',
                meta.border,
              ]}
            >
              <div class:list={[
                'absolute inset-0 rounded-2xl bg-gradient-to-br opacity-0 group-hover:opacity-100 transition-opacity duration-300 -z-10',
                meta.accent,
              ]}></div>

              <div class="plot-sprout" aria-hidden="true">
                <span class="plot-sprout__stem"></span>
                <span class="plot-sprout__leaf plot-sprout__leaf--left"></span>
                <span class="plot-sprout__leaf plot-sprout__leaf--right"></span>
              </div>

              <span class:list={[
                'text-xs font-black uppercase tracking-widest mb-3',
                meta.numColor,
              ]}>
                0{i + 1}
              </span>

              <div class:list={[
                'w-11 h-11 rounded-xl flex items-center justify-center mb-4 transition-transform duration-300 group-hover:scale-110',
                meta.iconBg,
              ]}>
                <Fragment set:html={meta.icon} />
              </div>

              <span class="text-sm md:text-base font-bold leading-snug" style="color:rgba(29,51,38,0.84);">
                {q}
              </span>

              <svg class="w-4 h-4 mt-3 opacity-0 group-hover:opacity-60 transition-all duration-300 group-hover:translate-y-0.5" style="color:rgba(29,51,38,0.42);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3" />
              </svg>
            </a>
          );
        })}
      </div>
    </div>
  </div>
</section>

<style>
  .field-questions-shell {
    position: relative;
    padding: 2rem 1.5rem;
    border-radius: 2rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.84), rgba(247, 241, 230, 0.96)),
      radial-gradient(circle at 50% 20%, rgba(148, 97, 45, 0.05), transparent 30%);
    border: 1px solid rgba(19, 50, 36, 0.08);
    box-shadow: 0 28px 56px rgba(0, 0, 0, 0.08);
    overflow: hidden;
  }

  .field-questions-shell__rows {
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.03) 0 2px,
        transparent 2px 32px
      ),
      linear-gradient(90deg, rgba(255, 255, 255, 0.02), transparent 8%, transparent 92%, rgba(255, 255, 255, 0.02));
    mask-image: linear-gradient(180deg, transparent 0%, black 12%, black 88%, transparent 100%);
  }

  .field-footprints {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .field-footprint {
    position: absolute;
    left: var(--foot-left);
    top: var(--foot-top);
    width: 14px;
    height: 26px;
    border-radius: 50% 50% 40% 40%;
    background: rgba(148, 97, 45, 0.08);
    box-shadow: 16px 6px 0 rgba(148, 97, 45, 0.05);
    opacity: 0;
    transform: scale(0.6) rotate(var(--foot-rotate));
    transition: opacity 0.35s ease, transform 0.35s ease;
    transition-delay: calc(var(--foot-index) * 0.09s);
  }

  [data-scene="guided"].scene-visible .field-footprint {
    opacity: 1;
    transform: scale(1) rotate(var(--foot-rotate));
  }

  .question-card {
    will-change: transform;
  }

  .question-plot-card {
    overflow: hidden;
  }

  .question-plot-card::after {
    content: '';
    position: absolute;
    inset: auto 14% 14px;
    height: 12px;
    border-bottom: 1px solid rgba(22, 163, 74, 0.22);
    border-radius: 999px;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .question-plot-card:hover::after {
    opacity: 1;
    transform: translateY(0);
  }

  .plot-sprout {
    position: absolute;
    left: 1rem;
    top: 1rem;
    width: 18px;
    height: 22px;
    opacity: 0.8;
  }

  .plot-sprout__stem {
    position: absolute;
    left: 50%;
    bottom: 0;
    width: 2px;
    height: 16px;
    border-radius: 999px;
    background: linear-gradient(180deg, rgba(34, 197, 94, 0.35), rgba(21, 128, 61, 0.9));
    transform: translateX(-50%);
  }

  .plot-sprout__leaf {
    position: absolute;
    bottom: 10px;
    width: 10px;
    height: 6px;
    background: linear-gradient(180deg, rgba(74, 222, 128, 0.95), rgba(22, 163, 74, 0.72));
  }

  .plot-sprout__leaf--left {
    left: 1px;
    border-radius: 100% 0 100% 0;
    transform: rotate(-24deg);
  }

  .plot-sprout__leaf--right {
    right: 1px;
    border-radius: 0 100% 0 100%;
    transform: rotate(24deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .question-card {
      transition: none;
    }

    .question-card:hover {
      transform: none;
    }

    .field-footprint {
      opacity: 1;
      transform: rotate(var(--foot-rotate));
      transition: none;
    }
  }
</style>
