---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/ui/Navbar.astro';
import Footer from '../../components/ui/Footer.astro';
import CinematicScrollHero from '../../components/islands/CinematicScrollHero';
import HeroSection from '../../components/sections/HeroSection.astro';
import ProblemHitSection from '../../components/sections/ProblemHitSection.astro';
import BeforeAfterSection from '../../components/sections/BeforeAfterSection.astro';
import WorkflowSection from '../../components/sections/WorkflowSection.astro';
import ClaritySection from '../../components/sections/ClaritySection.astro';
import ValueLadderSection from '../../components/sections/ValueLadderSection.astro';
import FAQSection from '../../components/sections/FAQSection.astro';
import TrustSection from '../../components/sections/TrustSection.astro';
import IdentityShiftSection from '../../components/sections/IdentityShiftSection.astro';
import LegacySection from '../../components/sections/LegacySection.astro';
import ParticipationSection from '../../components/sections/ParticipationSection.astro';
import CtaSection from '../../components/sections/CtaSection.astro';
import { getLangFromUrl, getTranslations } from '../../i18n/translations';

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
---

<BaseLayout
  title={t.meta.title}
  description={t.meta.description}
>
  <Navbar />

  <main>
    <!-- Ch.01 · The Field -->
    <CinematicScrollHero client:load lang="en" />
    <HeroSection />

    <!-- Ch.02 · The Pain -->
    <div class="section-divider" aria-hidden="true">
      <img src="/dividers/bag-torn-chaos.svg" alt="" width="320" height="80" loading="lazy" />
    </div>
    <ProblemHitSection />

    <!-- Ch.03 · The Shift -->
    <BeforeAfterSection />

    <!-- Ch.04 · Speak and We Sort -->
    <div class="section-divider" aria-hidden="true">
      <img src="/dividers/bag-stacked-solution.svg" alt="" width="320" height="80" loading="lazy" />
    </div>
    <WorkflowSection />

    <!-- Ch.05 · What You Will See -->
    <ClaritySection />

    <!-- Ch.06 · The 90-Day Return -->
    <div class="section-divider" aria-hidden="true">
      <img src="/dividers/bag-open-pouring.svg" alt="" width="320" height="80" loading="lazy" />
    </div>
    <ValueLadderSection />

    <!-- Ch.07 · Your Questions (consolidated accordion — replaces 5 QASections) -->
    <FAQSection />

    <!-- Ch.08 · Trust -->
    <div class="section-divider" aria-hidden="true">
      <img src="/dividers/bag-rupee-stamp.svg" alt="" width="320" height="80" loading="lazy" />
    </div>
    <TrustSection />

    <!-- Ch.09 · Who You Become -->
    <IdentityShiftSection />

    <!-- Ch.10 · Legacy -->
    <LegacySection />

    <!-- Ch.11 · Your Part -->
    <div class="section-divider" aria-hidden="true">
      <img src="/dividers/bag-certified.svg" alt="" width="320" height="80" loading="lazy" />
    </div>
    <ParticipationSection />

    <!-- Ch.12 · Begin -->
    <div class="section-divider" aria-hidden="true">
      <img src="/dividers/bag-folded-empty.svg" alt="" width="320" height="80" loading="lazy" />
    </div>
    <CtaSection />
  </main>

  <Footer />

  <script>
    import { initScrollAnimations } from '../../scripts/scrollAnimations';
    document.addEventListener('DOMContentLoaded', () => {
      initScrollAnimations();
    });
  </script>
</BaseLayout>
