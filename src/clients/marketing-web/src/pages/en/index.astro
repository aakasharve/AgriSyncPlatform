---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/ui/Navbar.astro';
import Footer from '../../components/ui/Footer.astro';
import CinematicScrollHero from '../../components/islands/CinematicScrollHero';
import HeroSection from '../../components/sections/HeroSection.astro';
import ProblemHitSection from '../../components/sections/ProblemHitSection.astro';
import BeforeAfterSection from '../../components/sections/BeforeAfterSection.astro';
import WorkflowSection from '../../components/sections/WorkflowSection.astro';
import ValueLadderSection from '../../components/sections/ValueLadderSection.astro';
import TrustSection from '../../components/sections/TrustSection.astro';
import LegacySection from '../../components/sections/LegacySection.astro';
import ParticipationSection from '../../components/sections/ParticipationSection.astro';
import CtaSection from '../../components/sections/CtaSection.astro';
import { getLangFromUrl, getTranslations } from '../../i18n/translations';

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
---

<BaseLayout
  title={t.meta.title}
  description={t.meta.description}
>
  <Navbar />

  <main>
    <!-- Ch.01 · The Field -->
    <CinematicScrollHero client:load lang="en" />
    <HeroSection />

    <div class="soil-stratum" aria-hidden="true"><span></span></div>

    <!-- Ch.02 · The Pain -->
    <ProblemHitSection />

    <!-- Ch.03 · The Shift -->
    <BeforeAfterSection />

    <div class="soil-stratum" aria-hidden="true"><span></span></div>

    <!-- Ch.04 · Speak and We Sort (+ Clarity pull-quote inside) -->
    <WorkflowSection />

    <div class="soil-stratum" aria-hidden="true"><span></span></div>

    <!-- Ch.05 · The 90-Day Return -->
    <ValueLadderSection />

    <div class="soil-stratum" aria-hidden="true"><span></span></div>

    <!-- Ch.06 · Trust -->
    <TrustSection />

    <div class="soil-stratum" aria-hidden="true"><span></span></div>

    <!-- Ch.07 · Legacy (+ IdentityShift pull-quote inside) -->
    <LegacySection />

    <div class="soil-stratum" aria-hidden="true"><span></span></div>

    <!-- Ch.08 · Your Part -->
    <ParticipationSection />

    <div class="soil-stratum" aria-hidden="true"><span></span></div>

    <!-- Ch.09 · Begin (+ 4-item FAQ accordion inside) -->
    <CtaSection />
  </main>

  <Footer />

  <script>
    import { initScrollAnimations } from '../../scripts/scrollAnimations';
    document.addEventListener('DOMContentLoaded', () => {
      initScrollAnimations();
    });
  </script>
</BaseLayout>
