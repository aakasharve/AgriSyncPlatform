{
  "name": "shramsafal-web",
  "private": true,
  "version": "0.9.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite --host",
    "build": "vite build",
    "build:prod": "vite build --mode production",
    "clean": "rimraf dist",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --max-warnings 9999 \"src/**/*.{ts,tsx}\"",
    "check:file-sizes": "node scripts/check-file-sizes.mjs",
    "check:storage-discipline": "node scripts/check-storage-discipline.mjs",
    "verify:mutation-queue": "node scripts/verify-mutation-queue.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:voice-pipeline": "tsx scripts/voice_pipeline_gate_check.ts",
    "test:doom-loop": "tsx scripts/ai_doom_loop_gate_check.ts",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install --with-deps",
    "audit:ai-calls": "node scripts/ai-call-audit.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/camera": "^8.0.2",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.1.0",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/keyboard": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@capgo/capacitor-navigation-bar": "^8.0.25",
    "@react-google-maps/api": "^2.20.8",
    "@types/qrcode": "^1.5.6",
    "@types/react-router-dom": "^5.3.3",
    "@types/uuid": "^10.0.0",
    "axios": "^1.13.5",
    "dexie": "^4.3.0",
    "lucide-react": "^0.554.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.13.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^16.3.2",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^22.14.0",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.27",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.5.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.8",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.59.0",
    "vite": "^6.2.0",
    "vitest": "^3.2.4"
  }
}
