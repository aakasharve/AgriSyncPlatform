# ShramSafal frontend environment variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# Required: backend URL for auth + sync APIs
VITE_AGRISYNC_API_URL=http://localhost:5000

# Optional: only set if the weather feature is explicitly shipping
# VITE_WEATHER_API_KEY=your_weather_api_key_here

# Optional: only set if plot mapping is explicitly shipping
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# OpenTelemetry browser tracing (disabled in production until a prod collector is provisioned).
# Set VITE_OTEL_ENABLED=1 in your local .env to enable traceparent propagation to the backend.
# VITE_OTEL_ENABLED=0
# VITE_OTEL_ENDPOINT=http://localhost:4318/v1/traces

# Nothing else belongs in the production frontend env.
