<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\ShramSafal.Domain\ShramSafal.Domain.csproj" />
    <ProjectReference Include="..\..\..\AgriSync.SharedKernel\AgriSync.SharedKernel.csproj" />
    <ProjectReference Include="..\..\..\AgriSync.BuildingBlocks\AgriSync.BuildingBlocks.csproj" />
  </ItemGroup>

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <!-- T-IGH-02-CS-PAYLOADS — single source of truth for sync mutation
       payloads. Generated from sync-contract/schemas/payloads/*.zod.ts
       by `npm run generate:csharp` (Zod runtime introspection → C#).
       Linked rather than copied so the on-disk files live next to the
       Zod schemas they're generated from. Regenerate after every Zod
       change via `cd sync-contract && npm run generate`. -->
  <ItemGroup>
    <Compile Include="..\..\..\..\sync-contract\schemas\payloads-csharp\*.cs">
      <Link>Contracts\Sync\Payloads\%(Filename)%(Extension)</Link>
    </Compile>
  </ItemGroup>

</Project>
