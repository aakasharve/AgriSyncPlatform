{
  "ConnectionStrings": {
    "UserDb": "Host=localhost;Port=5433;Database=agrisync_dev;Username=postgres;Password=CHANGE_ME",
    "ShramSafalDb": "Host=localhost;Port=5433;Database=agrisync_dev;Username=postgres;Password=CHANGE_ME"
  },
  "Jwt": {
    "Issuer": "AgriSync",
    "Audience": "AgriSync.Clients",
    "SigningKey": "DEV-ONLY-CHANGE-IN-PROD-min-32-chars!!",
    "AccessTokenMinutes": 15
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:4000",
      "http://127.0.0.1:5173",
      "capacitor://localhost",
      "http://localhost"
    ]
  },
  "ShramSafal": {
    "Storage": {
      "DataDirectory": "App_Data",
      "Provider": "Local"
    }
  },
  "Gemini": {
    "ApiKey": "",
    "ModelId": "gemini-2.5-flash",
    "TimeoutSeconds": 30,
    "Temperature": 0.2,
    "MaxTokens": 4096,
    "BaseUrl": "https://generativelanguage.googleapis.com/v1beta"
  },
  "Sarvam": {
    "ApiSubscriptionKey": "",
    "SttEndpoint": "https://api.sarvam.ai/speech-to-text",
    "SttModel": "saaras:v3",
    "SttMode": "transcribe",
    "SttLanguage": "unknown",
    "ChatEndpoint": "https://api.sarvam.ai/v1/chat/completions",
    "ChatModel": "sarvam-m",
    "VisionModel": "sarvam-vision",
    "ChatTemperature": 0.2,
    "TimeoutSeconds": 45
  },
  "Weather": {
    "TomorrowIo": {
      "ApiKey": "",
      "BaseUrl": "https://api.tomorrow.io/v4",
      "TimeoutSeconds": 15
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
