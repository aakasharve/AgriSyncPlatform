{
  "ConnectionStrings": {
    "UserDb": "Host=localhost;Port=5432;Database=agrisync;Username=postgres;Password=postgres",
    "ShramSafalDb": "Host=localhost;Port=5432;Database=agrisync;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "AgriSync",
    "Audience": "AgriSync.Clients",
    "SigningKey": "CHANGE_ME_IN_CONFIGURATION_MIN_32_CHARS",
    "AccessTokenMinutes": 60
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
