{
  "ConnectionStrings": {
    "UserDb": "Host=localhost;Port=5433;Database=agrisync;Username=postgres;Password=CHANGE_ME_IN_ENVIRONMENT",
    "ShramSafalDb": "Host=localhost;Port=5433;Database=agrisync;Username=postgres;Password=CHANGE_ME_IN_ENVIRONMENT"
  },
  "Jwt": {
    "Issuer": "AgriSync",
    "Audience": "AgriSync.Clients",
    "SigningKey": "CHANGE_ME_IN_CONFIGURATION_MIN_32_CHARS",
    "AccessTokenMinutes": 60
  },
  "ShramSafal": {
    "Storage": {
      "DataDirectory": "App_Data"
    }
  },
  "Gemini": {
    "ApiKey": "CHANGE_ME",
    "ModelId": "gemini-2.5-flash",
    "TimeoutSeconds": 30,
    "Temperature": 0.2,
    "MaxTokens": 4096,
    "BaseUrl": "https://generativelanguage.googleapis.com/v1beta"
  },
  "Sarvam": {
    "ApiSubscriptionKey": "CHANGE_ME",
    "SttEndpoint": "https://api.sarvam.ai/speech-to-text",
    "SttModel": "saaras:v3",
    "SttMode": "transcribe",
    "SttLanguage": "unknown",
    "ChatEndpoint": "https://api.sarvam.ai/v1/chat/completions",
    "ChatModel": "sarvam-m",
    "VisionModel": "sarvam-vision",
    "ChatTemperature": 0.2,
    "TimeoutSeconds": 45
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
