{
  "ConnectionStrings": {
    "UserDb": "OVERRIDE_VIA_ENVIRONMENT_VARIABLE",
    "ShramSafalDb": "OVERRIDE_VIA_ENVIRONMENT_VARIABLE"
  },
  "Jwt": {
    "Issuer": "AgriSync",
    "Audience": "AgriSync.Clients",
    "SigningKey": "OVERRIDE_VIA_ENVIRONMENT_VARIABLE",
    "AccessTokenMinutes": 15
  },
  "Cors": {
    "AllowedOrigins": [
      "https://app.shramsafal.in",
      "https://shramsafal.in",
      "capacitor://localhost",
      "https://localhost",
      "http://localhost"
    ]
  },
  "ShramSafal": {
    "Storage": {
      "Provider": "S3",
      "BucketName": "shramsafal-uploads-prod",
      "Region": "ap-south-1",
      "KeyPrefix": "attachments/"
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "/var/log/agrisync/api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "fileSizeLimitBytes": 52428800,
          "shared": true
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  }
}
