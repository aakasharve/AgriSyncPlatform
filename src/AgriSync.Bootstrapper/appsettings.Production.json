{
  "ConnectionStrings": {
    "UserDb": "OVERRIDE_VIA_ENVIRONMENT_VARIABLE",
    "ShramSafalDb": "OVERRIDE_VIA_ENVIRONMENT_VARIABLE",
    "UserDb_Migration": "OVERRIDE_VIA_ENVIRONMENT_VARIABLE",
    "UserDb_ReadOnly": "OVERRIDE_VIA_ENVIRONMENT_VARIABLE",
    "ShramSafalDb_Migration": "OVERRIDE_VIA_ENVIRONMENT_VARIABLE",
    "ShramSafalDb_ReadOnly": "OVERRIDE_VIA_ENVIRONMENT_VARIABLE"
  },
  "Jwt": {
    "Issuer": "AgriSync",
    "Audience": "AgriSync.Clients",
    "SigningKey": "OVERRIDE_VIA_ENVIRONMENT_VARIABLE",
    "AccessTokenMinutes": 15
  },
  "Cors": {
    "AllowedOrigins": [
      "https://app.shramsafal.in",
      "https://shramsafal.in",
      "https://admin.shramsafal.in",
      "capacitor://localhost",
      "https://localhost",
      "http://localhost"
    ]
  },
  "ShramSafal": {
    "Storage": {
      "Provider": "S3",
      "BucketName": "shramsafal-uploads-prod",
      "Region": "ap-south-1",
      "KeyPrefix": "attachments/"
    }
  },
  "Gemini": {
    "StructurerModelId": "gemini-3.1-flash-lite-preview",
    "OcrModelId": "gemini-2.5-flash",
    "VoiceFallbackModelId": "gemini-2.5-flash",
    "TimeoutSeconds": 30,
    "Temperature": 0.2,
    "MaxTokens": 4096,
    "BaseUrl": "https://generativelanguage.googleapis.com/v1beta"
  },
  "TestLogin": {
    "Enabled": false,
    "AllowedPhoneNumbersE164": []
  },
  "Sarvam": {
    "SttEndpoint": "https://api.sarvam.ai/speech-to-text",
    "SttModel": "saaras:v3",
    "SttMode": "codemix",
    "SttLanguage": "mr-IN",
    "StreamingSttEndpoint": "wss://api.sarvam.ai/speech-to-text/ws",
    "StreamingSttModel": "saaras:v3",
    "StreamingSttMode": "codemix",
    "StreamingSttLanguage": "mr-IN",
    "StreamingSampleRate": 16000,
    "StreamingInputAudioCodec": "wav",
    "StreamingHighVadSensitivity": true,
    "StreamingVadSignals": true,
    "StreamingFlushSignal": true,
    "StreamingTimeoutSeconds": 30,
    "ChatEndpoint": "https://api.sarvam.ai/v1/chat/completions",
    "ChatModel": "sarvam-m",
    "VisionModel": "sarvam-vision",
    "ChatTemperature": 0.2,
    "TimeoutSeconds": 45
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "/var/log/agrisync/api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "fileSizeLimitBytes": 52428800,
          "shared": true
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  }
}
