# ============================================
# AgriSync Platform .gitignore
# Protocol: REPO_HYGIENE_PROTOCOL.md (in _COFOUNDER/01_Operations/Protocols/)
# Last updated: 2026-03-15
# ============================================

# ===========================================
# §1  PERSONAL / AGENTIC WORKFLOW
#     Never commit. These are local tools,
#     not application code.
# ===========================================

# Junk quarantine — auto-managed by /repo-clean
junk/

# Operations vault (Obsidian knowledge base)
/_COFOUNDER/
.obsidian/

# AI agent configs (Claude, Gemini, Codex)
.claude/
.gemini/
.mcp.json
*.skill
*.canvas
.superpowers/
.agents/
.kiro/
__pycache__/

# Stray _COFOUNDER sub-folders at root (safety net)
/00_Home/
/00_Strategy/
/01_Operations/
/02_Quality/
/02_Skills/
/03_Documentation/
/04_Product/
/05_Engineering/
/99_System_State/

# Protocol docs (for agents, not for the repo)
/REPO_HYGIENE_PROTOCOL.md

# ===========================================
# §2  SECRETS & CREDENTIALS
#     .env.example is committed (template).
#     Real values NEVER committed.
# ===========================================

.env
.env.local
.env.*.local
src/AgriSync.Bootstrapper/secrets/
src/AgriSync.Bootstrapper/App_Data/
# Dev connection strings / local overrides — copy appsettings.Development.example.json and fill in locally
src/AgriSync.Bootstrapper/appsettings.Development.json
*.keystore
*.jks

# ===========================================
# §3  BUILD ARTIFACTS
#     Reproducible from source. Never commit.
# ===========================================

# .NET
.vs/
*.user
*.suo
**/bin/
**/obj/
*.nupkg
**/packages/

# Node / Frontend
node_modules/
**/dist/

# Capacitor native (built locally per-device)
src/clients/mobile-web/android/
src/clients/mobile-web/ios/

# Astro generated types (rebuilt on `astro dev`)
**/.astro/

# Python virtual environments
venv*/

# ===========================================
# §4  IDE & OS
# ===========================================

.idea/
.vscode/
Thumbs.db
.DS_Store

# ===========================================
# §5  LOGS, TEMP FILES & DEBUG SCRATCH
#     Agents: use /tmp or outside the repo.
#     NEVER dump debug output into src tree.
# ===========================================

# Log files
*.log
*.err.log
*.out.log

# Android crash/replay dumps
android/hs_err_pid*.log
android/replay_pid*.log

# Agent temp files (preview servers etc.)
/tmp/agrisync-*.log
/tmp/agrisync-*.pid

# Agent debug dumps (catch-all patterns)
build_out.txt
build_error.txt
**/build_error.txt
diff.txt
diff_content.txt
diff_stat.txt
status*.txt
snapshot_commits.txt
uncommitted_files.txt
tmp-swagger.json
debug_seed.ps1
out.txt
out[0-9]*.txt
err.txt
err.json
error_out.txt
out_upload.txt
**/check*.txt
**/check_output.txt

# Codex temp files
.codex_build/
.codex_tmp_handoff_result.json

# Preview server PIDs
.preview_backend_pid
.preview_frontend_pid

# Test/debug scratch (underscore-prefixed at root)
/_*.txt
_test_output*.txt
_sarvam_*.txt
_sarvam_*.json
_domain_tests.txt
_err.txt
_git_vision.txt
_integr_tests.txt
/output/
/_deploy/

# ===========================================
# §6  TESTING & CI ARTIFACTS
# ===========================================

.playwright-cli/
.playwright-mcp/
**/.vite/
**/output/*.png
**/output/*.jpg
src/clients/mobile-web/vite_log.txt

# Build / tsc artifact dumps — never commit these
**/build_log.txt
**/errors.txt
**/raw_tsc_errors.txt
**/tsc_errors.txt

# ===========================================
# §7  MARKETING SITE
#     Not ignored — owner commits when ready.
#     Appears as untracked in git status until then.
# ===========================================

# Root-level scratch scripts used for asset generation
/scripts/

# ===========================================
# §8  LEGACY / MISC
# ===========================================

*.generated.*
*.msi
/publish/
/marketing/
/aws_*.log
/patch_*.js

# ===========================================
# §9  DEMO ASSETS (large binaries, local only)
# ===========================================

src/clients/mobile-web/public/demo-photos/*.jpg
src/clients/mobile-web/public/demo-photos/*.jpeg
src/clients/mobile-web/public/demo-photos/*.png

# Caveman ecosystem data (per-project runtime stores)
.cavemem/**

# .mcp.json mutation backups
.mcp.json.bak-*
.mcp.json.tmp
.mcp.json.new

# UI/UX Gate runtime files (per-developer, per-commit)
.uiux-gate-passed
.uiux-gallery/
.interface-design/
.uiux-design-mode.json

.worktrees/

# ============================================
# §11  Playwright / E2E artifacts
#      Sub-plan 05 introduces a real E2E suite.
#      These globs prevent accidental tracking
#      of generated screenshots, traces, videos.
# ============================================
test-results/
playwright-report/
**/playwright-report/
**/test-results/
**/*.spec.png
**/*.snap.png
**/__screenshots__/
**/__diff_output__/
**/blob-report/
.vitest/
.coverage/
coverage/

# ============================================
# §12  Build artifacts that occasionally slip in
# ============================================
**/dist-ssr/
**/.turbo/
